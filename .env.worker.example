# WP-7 — background worker environment (copy to the host's env settings; never commit real values)

# Supabase Postgres — use the SESSION pooler (5432) or direct connection for the
# long-running worker, NOT the 6543 transaction pooler (BullMQ + interactive
# transactions want session semantics). Strip any ?pgbouncer=true parameter.
DATABASE_URL="postgresql://<user>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://<user>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"

# Upstash Redis (or any Redis ≥ 6). Use the TLS URL (rediss://) from the
# Upstash console. The worker exits non-zero if this is missing — it never
# falls back to localhost (PR-002).
REDIS_URL="rediss://default:<password>@<name>.upstash.io:6379"

# Outbound email for the notifications worker (same values as the Vercel app).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="claims@medvex.co.ug"
