generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── TENANT ──────────────────────────────────────────────
model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  primaryColor String   @default("#000523")
  accentColor  String   @default("#06B9AB")
  warmColor    String   @default("#F2715A")
  fontHeading  String   @default("Sora")
  fontBody     String   @default("Hanken Grotesk")
  domain       String?  @unique
  config       Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users                          User[]
  groups                         Group[]
  members                        Member[]
  packages                       Package[]
  claims                         Claim[]
  preauths                       PreAuthorization[]
  providers                      Provider[]
  providerContracts              ProviderContract[]
  brokers                        Broker[]
  endorsements                   Endorsement[]
  invoices                       Invoice[]
  quotations                     Quotation[]
  exceptionLogs                  ExceptionLog[]
  chartOfAccounts                ChartOfAccount[]
  journalEntries                 JournalEntry[]
  fraudAlerts                    ClaimFraudAlert[]
  complaints                     Complaint[]
  coContributionRules            CoContributionRule[]
  annualCoContributionCaps       AnnualCoContributionCap[]
  coContributionTransactions     CoContributionTransaction[]
  memberCoContributionPayments   MemberCoContributionPayment[]
  memberAnnualCoContributions    MemberAnnualCoContribution[]
  familyAnnualCoContributions    FamilyAnnualCoContribution[]
  selfFundedAccounts             SelfFundedAccount[]
  fundTransactions               FundTransaction[]
  taxRates                       TaxRate[]
  approvalMatrices               ApprovalMatrix[]
  memberWebAuthnCredentials      MemberWebAuthnCredential[]
  webAuthnRegistrationChallenges WebAuthnRegistrationChallenge[]
  webAuthnEnrollmentApprovals    WebAuthnEnrollmentApproval[]
  checkInChallenges              CheckInChallenge[]
  checkInEvents                  CheckInEvent[]
  memberCheckInNotifications     MemberCheckInNotification[]
  memberNotifications            MemberNotification[]
  memberHealthFiles              MemberHealthFile[]
  memberVitalEntries             MemberVitalEntry[]
  memberHealthJournalEntries     MemberHealthJournalEntry[]
  memberHealthShares             MemberHealthShare[]
  visitVerifications             VisitVerification[]
  practitioners                  Practitioner[]
  reinstatementRequests          MembershipReinstatementRequest[]
  roles                          Role[]
  overrideRecords                OverrideRecord[]
  blacklistEntries               InternalBlacklist[]
  userRoleAssignments            UserRoleAssignment[]
  clients                        Client[]
  terminologyEntries             TerminologyEntry[]
  terminologyApprovals           TerminologyApproval[]
  approvalRequests               ApprovalRequest[]
  fxRates                        FxRate[]
  syncOperations                 SyncOperation[]
  offlineReservations            OfflineReservation[]
  eligibilitySnapshots           EligibilitySnapshot[]
  autoAdjudicationPolicies       AutoAdjudicationPolicy[]
  drugExclusions                 DrugExclusion[]
  adminFeeAgreements             AdminFeeAgreement[]
  adminFeeLedgerEntries          AdminFeeLedgerEntry[]
  regulatoryLicences             RegulatoryLicence[]
  securityDeposits               SecurityDeposit[]
  directorRegister               DirectorRegister[]
  indemnityCovers                IndemnityCover[]
  complianceLevyComputations     ComplianceLevyComputation[]
  consentRecords                 ConsentRecord[]
  dataSubjectRequests            DataSubjectRequest[]
  processorRegister              ProcessorRegister[]
  breachIncidents                BreachIncident[]
  fraudRules                     FraudRule[]
  fraudInvestigations            FraudInvestigation[]
}

// ── Multi-client TPA tenancy (Medvex spec §2.1 / gap G2.1) ──────────────
// AD-1: `Tenant` stays the Medvex *operator* (the TPA itself). `Client` is the
// per-payer boundary below it — an insurer, HMO, or self-funded employer whose
// schemes (Group) Medvex administers. Cross-client isolation is a hard security
// boundary; nearly every client-scoped entity will gain a `clientId` over the
// Phase-0/1 rollout. This first slice introduces the entity + scheme link only.
enum PayerType {
  INSURER // Risk-bearing insurance company
  HMO // Health maintenance organisation
  EMPLOYER_SELF_FUNDED // Employer funds its own scheme; Medvex administers
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  SUSPENDED
  TERMINATED
}

model Client {
  id               String   @id @default(cuid())
  operatorTenantId String // the Medvex operator that administers this client
  operatorTenant   Tenant   @relation(fields: [operatorTenantId], references: [id])
  parentClientId   String? // set for a subsidiary of a regional/parent client
  parentClient     Client?  @relation("ClientHierarchy", fields: [parentClientId], references: [id])
  subsidiaries     Client[] @relation("ClientHierarchy")

  type PayerType
  name String
  slug String // unique per operator (see @@unique)

  // Transaction currency for this client (ISO 4217). Base for the platform is
  // UGX (AD-2); subsidiaries may differ and consolidate up via FX in G3.5.
  currency String @default("UGX")

  // Member/policy number prefix (G9.6) — client-configurable, replaces the
  // legacy hard-coded operator prefix. Format: {prefix}-{YYYY}-{NNNNN}.
  memberNumberPrefix String @default("MVX")

  // Branding overrides — null inherits the operator's Medvex brand.
  logoUrl      String?
  primaryColor String?
  accentColor  String?
  warmColor    String?

  // Per-client config bag (terminology dictionary ref, approval-matrix scope,
  // report templates, etc. attach here / via FKs as those engines land).
  config Json @default("{}")

  // Never-delete lifecycle (activate/deactivate + effective dating).
  status        ClientStatus @default(ACTIVE)
  isActive      Boolean      @default(true)
  effectiveFrom DateTime     @default(now())
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups             Group[]
  users              User[]
  terminologyEntries TerminologyEntry[]
  approvalMatrices   ApprovalMatrix[]
  approvalRequests   ApprovalRequest[]
  providerTariffs    ProviderTariff[]
  autoAdjudicationPolicies AutoAdjudicationPolicy[]
  copayRules         CoContributionRule[]
  drugExclusions     DrugExclusion[]
  adminFeeAgreements AdminFeeAgreement[]
  adminFeeLedgerEntries AdminFeeLedgerEntry[]
  fraudRules         FraudRule[]

  @@unique([operatorTenantId, slug])
  @@index([operatorTenantId])
  @@index([operatorTenantId, status])
  @@index([parentClientId])
}

// ── Terminology engine (Medvex spec §2.4 / gap G2.4) ───────────────────
// Each client presents its own vocabulary while enums stay canonical in code.
// resolve(clientId, key) walks most-specific → least: CLIENT → LOCALE → HOUSE
// → SYSTEM, with a code-level fallback last. Never-delete + maker-checker.
enum TerminologyScope {
  SYSTEM // canonical platform default
  HOUSE // Medvex house vocabulary (operator-wide)
  CLIENT // per-client override (highest precedence)
  LOCALE // locale/language-specific
}

enum TerminologyStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model TerminologyEntry {
  id       String           @id @default(cuid())
  tenantId String
  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  scope    TerminologyScope
  clientId String? // required when scope = CLIENT
  client   Client?          @relation(fields: [clientId], references: [id])
  locale   String? // e.g. "en-UG"; used for scope = LOCALE or locale-specific overrides

  key         String // canonical term key, e.g. "policy", "premium", "claim"
  displayText String // what to render in the UI for this key
  context     String? // optional usage note / where it applies

  status        TerminologyStatus @default(DRAFT)
  isActive      Boolean           @default(true)
  effectiveFrom DateTime          @default(now())
  effectiveTo   DateTime?
  createdById   String?
  approvedById  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvals TerminologyApproval[]

  @@index([tenantId, key])
  @@index([tenantId, scope, key])
  @@index([tenantId, status])
  @@index([clientId])
}

model TerminologyApproval {
  id       String           @id @default(cuid())
  tenantId String
  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  entryId  String
  entry    TerminologyEntry @relation(fields: [entryId], references: [id])
  action   String // SUBMITTED | APPROVED | REJECTED
  byUserId String
  notes    String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([entryId])
}

// ─── USERS & AUTH ────────────────────────────────────────
enum UserRole {
  SUPER_ADMIN
  CLAIMS_OFFICER
  FINANCE_OFFICER
  UNDERWRITER
  CUSTOMER_SERVICE
  MEDICAL_OFFICER
  REPORTS_VIEWER
  BROKER_USER
  MEMBER_USER
  HR_MANAGER
  FUND_ADMINISTRATOR // Employer finance officer managing self-funded scheme(s)
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  // Client confinement (G2.1). null = operator-level Medvex ops user who spans
  // every client in the tenant; set = user is confined to this one client.
  clientId     String?
  client       Client?   @relation(fields: [clientId], references: [id])
  email        String
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  // Single-session control (R25/H-03): bumped on each login; a JWT carrying an
  // older version is invalidated, so only the most recent login stays valid.
  sessionVersion Int     @default(0)
  // Two-factor auth (R81/H-01): base32 TOTP secret + enabled flag.
  totpSecret   String?
  totpEnabled  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Link to broker or member profile
  brokerId String? @unique
  broker   Broker? @relation(fields: [brokerId], references: [id])
  memberId String? @unique
  member   Member? @relation(fields: [memberId], references: [id])
  groupId  String?
  group    Group?  @relation("HRManagerGroup", fields: [groupId], references: [id])

  managedFundGroups           Group[]                          @relation("FundAdminGroups")
  auditLogs                   AuditLog[]
  claimReviews                Claim[]                          @relation("ClaimReviewer")
  raisedExceptions            ExceptionLog[]                   @relation("ExceptionRaisedBy")
  resolvedExceptions          ExceptionLog[]                   @relation("ExceptionResolvedBy")
  roleAssignments             UserRoleAssignment[]
  madeOverrides               OverrideRecord[]                 @relation("OverrideMaker")
  checkedOverrides            OverrideRecord[]                 @relation("OverrideChecker")
  blacklistEntries            InternalBlacklist[]              @relation("BlacklistAdder")
  assignedQuotations          Quotation[]                      @relation("QuotationAssessor")
  assessorWorkQueueItems      AssessorWorkQueueItem[]
  underwritingDecisions       UnderwritingDecision[]           @relation("UWDecider")
  acceptances                 QuotationAcceptance[]            @relation("AcceptanceUser")
  madeEndorsements            Endorsement[]                    @relation("EndorsementMaker")
  approvedEndorsements        Endorsement[]                    @relation("EndorsementApprover")
  adjudicatedClaims           Claim[]                          @relation("ClaimAdjudicator")
  seniorApprovedClaims        Claim[]                          @relation("ClaimSeniorAdjudicator")
  submittedServiceRequests    ServiceRequest[]                 @relation("SRSubmitter")
  respondedServiceRequests    ServiceRequest[]                 @relation("SRResponder")
  escalatedPreauths           PreAuthorization[]               @relation("PreauthEscalation")
  initiatedCheckIns           CheckInChallenge[]               @relation("CheckInInitiatedBy")
  initiatedCheckInEvents      CheckInEvent[]                   @relation("CheckInEventInitiatedBy")
  overrideCheckInEvents       CheckInEvent[]                   @relation("CheckInEventOverrideBy")
  confirmedVisits             VisitVerification[]              @relation("VisitConfirmedBy")
  webAuthnEnrollmentApprovals WebAuthnEnrollmentApproval[]     @relation("WebAuthnEnrollmentApprovedBy")
  reinstatementDecisions      MembershipReinstatementRequest[]
  passwordResetTokens         PasswordResetToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([clientId])
}

// Password reset via emailed one-time code (Medvex spec §6 / R24 / gap H-02).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  codeHash  String // bcrypt hash of the 6-digit code (never stored in clear)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─── GROUPS / ORGANIZATIONS ─────────────────────────────
enum GroupStatus {
  PROSPECT
  PENDING
  ACTIVE
  SUSPENDED
  LAPSED
  TERMINATED
}

enum PaymentFrequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum FundingMode {
  INSURED // Traditional risk-bearing — premium underwriting
  SELF_FUNDED // Client deposits a fund; broker administers; admin fee charged
}

enum ClientType {
  CORPORATE // Employer / organization scheme
  INDIVIDUAL // Single person / family — no employer group
}

enum FamilySize {
  M
  M_1
  M_2
  M_3
  M_4
  M_5
  M_6
  M_7
  M_7_PLUS
}

enum AdminFeeMethod {
  FLAT_PER_INSURED // Fixed fee per member at policy start
  PCT_OF_CLAIMS // Percentage of total claims paid, computed post-period
  PMPM // Per-member-per-month, accrued monthly from active-member counts (G2.3)
  CASE_MGMT // Per case-management episode
  PREAUTH // Per pre-authorization / GOP
  CROSS_BORDER // Per cross-border coordination
  CARD_ISSUANCE // Per card issued
  CARD_REPLACEMENT // Per card replacement
}

enum AdminFeeLedgerStatus {
  ACCRUED // earned, not yet invoiced
  INVOICED // rolled into an invoice
  WAIVED
}

// TPA admin-fee agreements (Medvex spec §2.3 / gap G2.3). The TPA's primary
// revenue line: fees configured per client/scheme by method. Feeds the
// AdminFeeLedger (system of record) and, via that, invoicing + the IRA levy (G1.1).
model AdminFeeAgreement {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  clientId String? // per-client agreement
  client   Client? @relation(fields: [clientId], references: [id])
  groupId  String? // optional per-scheme override
  group    Group?  @relation(fields: [groupId], references: [id])

  method   AdminFeeMethod
  rate     Decimal // interpretation depends on method (amount per member/case/card, or % for PCT_OF_CLAIMS)
  currency String         @default("UGX")

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgerEntries AdminFeeLedgerEntry[]

  @@index([tenantId, clientId])
  @@index([tenantId, method])
}

// Admin-fee ledger — the system of record for fees earned, per period per client.
model AdminFeeLedgerEntry {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  clientId    String?
  client      Client?            @relation(fields: [clientId], references: [id])
  agreementId String?
  agreement   AdminFeeAgreement? @relation(fields: [agreementId], references: [id])

  method   AdminFeeMethod
  period   String // e.g. "2026-07" (PMPM/PCT) or "" for event-driven
  basis    Decimal? // the driver (member count, claims paid, etc.) for audit
  amount   Decimal
  currency String               @default("UGX")
  status   AdminFeeLedgerStatus @default(ACCRUED)
  invoiceId String?

  createdAt DateTime @default(now())

  @@index([tenantId, clientId, period])
  @@index([tenantId, status])
}

// ── TPA compliance register (Medvex spec §1.1 / gap G1.1) ───────────────
// The operator's own regulatory standing (IRA-UG): licence, security deposit,
// director register, indemnity cover, and the annual compliance-levy return
// (computed from the admin-fee ledger — the fees-received system of record).
enum LicenceStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  PENDING
}

model RegulatoryLicence {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  type        String // e.g. "TPA_LICENCE"
  number      String
  issuer      String        @default("IRA-UG")
  issuedAt    DateTime
  expiresAt   DateTime
  status      LicenceStatus @default(ACTIVE)
  documentRef String? // MinIO object ref
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@index([tenantId, expiresAt])
}

model SecurityDeposit {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  amount      Decimal
  currency    String    @default("UGX")
  evidenceRef String?
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
}

model DirectorRegister {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  name          String
  role          String?
  isResident    Boolean   @default(false) // Uganda-resident director flag
  appointedAt   DateTime
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model IndemnityCover {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  insurer     String
  sumInsured  Decimal
  currency    String   @default("UGX")
  periodStart DateTime
  periodEnd   DateTime
  documentRef String?
  createdAt   DateTime @default(now())

  @@index([tenantId])
}

model ComplianceLevyComputation {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  period             String // e.g. "2026"
  feesReceivedBasis  Decimal // from the admin-fee ledger
  ratePercent        Decimal // levy rate applied
  amount             Decimal
  currency           String   @default("UGX")
  status             String   @default("DRAFT") // DRAFT | FILED
  generatedReturnRef String?
  createdAt          DateTime @default(now())

  @@unique([tenantId, period])
  @@index([tenantId])
}

// ── Data protection (Uganda DPPA-2019 / gap G1.2) ──────────────────────
// Consent ledger, data-subject-rights handling, processor/sub-processor
// register, and breach workflow. PDPO (NITA-U) is the UG analogue of Kenya's
// ODPC. memberId is a scalar ref (avoids widening the Member model here).
model ConsentRecord {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  memberId    String
  purpose     String // e.g. "CLAIMS_PROCESSING", "HEALTH_DATA_SHARING"
  lawfulBasis String // e.g. "CONSENT", "CONTRACT", "LEGAL_OBLIGATION"
  version     String // consent-notice version
  channel     String? // ONBOARDING | PORTAL | USSD
  grantedAt   DateTime  @default(now())
  withdrawnAt DateTime?

  @@index([tenantId, memberId])
  @@index([tenantId, memberId, purpose])
}

enum DsrType {
  ACCESS
  CORRECTION
  OBJECTION
  ERASURE
}

enum DsrStatus {
  RECEIVED
  IN_PROGRESS
  FULFILLED
  REJECTED
}

model DataSubjectRequest {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  memberId      String
  type          DsrType
  status        DsrStatus @default(RECEIVED)
  slaDeadlineAt DateTime // statutory fulfilment deadline
  fulfilmentRef String? // export/endorsement artefact
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, memberId])
}

model ProcessorRegister {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  name           String
  role           String // "PROCESSOR" | "SUB_PROCESSOR"
  dataCategories String[]
  location       String? // data-residency / cross-border assessment
  dpaRef         String? // data-processing-agreement ref
  subProcessors  String[]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@index([tenantId])
}

enum BreachSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model BreachIncident {
  id                String         @id @default(cuid())
  tenantId          String
  tenant            Tenant         @relation(fields: [tenantId], references: [id])
  detectedAt        DateTime
  scope             String
  severity          BreachSeverity
  notifiableBy      DateTime? // regulator-notification deadline
  regulatorNotified Boolean        @default(false)
  narrative         String?
  remediation       String?
  createdAt         DateTime       @default(now())

  @@index([tenantId])
  @@index([tenantId, severity])
}

// ── Configurable fraud engine + investigations (Medvex spec §5.11 / gap G5.11
//    / AICARE_TODO F-01…F-12) ──────────────────────────────────────────
// Promotes the hard-coded deterministic rules into client-configurable rules,
// with an investigation workflow over the alerts they raise.
model FraudRule {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  clientId    String? // null = operator default; set = per-client override
  client      Client? @relation(fields: [clientId], references: [id])
  code        String // e.g. "PHANTOM_BILLING", "DUAL_INVOICING", "UPCODING"
  name        String
  description String?
  config      Json    @default("{}") // thresholds/parameters
  weight      Int     @default(1) // score/severity weight
  enabled     Boolean @default(true)

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, clientId, code])
  @@index([tenantId, clientId])
  @@index([tenantId, enabled])
}

enum FraudInvestigationStatus {
  OPEN
  IN_PROGRESS
  SUBSTANTIATED
  DISMISSED
}

model FraudInvestigation {
  id           String                   @id @default(cuid())
  tenantId     String
  tenant       Tenant                   @relation(fields: [tenantId], references: [id])
  claimId      String?
  fraudAlertId String?
  status       FraudInvestigationStatus @default(OPEN)
  assigneeId   String?
  findings     String?
  outcome      String?

  openedAt DateTime  @default(now())
  closedAt DateTime?

  @@index([tenantId, status])
  @@index([claimId])
}

enum FundTransactionType {
  DEPOSIT
  TOP_UP
  CLAIM_DEDUCTION
  ADMIN_FEE
  REFUND
  ADJUSTMENT
}

model Group {
  currency String @default("UGX") // G3.5 multi-currency (base UGX)
  id                        String              @id @default(cuid())
  tenantId                  String
  tenant                    Tenant              @relation(fields: [tenantId], references: [id])
  // Client payer that owns this scheme (G2.1). Required: every scheme belongs to
  // exactly one client. All create paths resolve it via resolveSchemeClientId()
  // (confined/selected client, else the operator tenant's default client).
  clientId                  String
  client                    Client              @relation(fields: [clientId], references: [id])
  name                      String
  industry                  String?
  registrationNumber        String?
  contactPersonName         String
  contactPersonPhone        String
  contactPersonEmail        String
  address                   String?
  county                    String?
  packageId                 String
  package                   Package             @relation(fields: [packageId], references: [id])
  packageVersionId          String?
  packageVersion            PackageVersion?     @relation(fields: [packageVersionId], references: [id])
  brokerId                  String?
  broker                    Broker?             @relation(fields: [brokerId], references: [id])
  producers                 BrokerProducer[]    @relation("ProducerSchemes")
  paymentFrequency          PaymentFrequency    @default(ANNUAL)
  contributionRate          Decimal // Per-member contribution amount
  effectiveDate             DateTime
  renewalDate               DateTime
  status                    GroupStatus         @default(PENDING)
  suspendedAt               DateTime?
  suspensionReason          String?
  terminatedAt              DateTime?
  notes                     String?
  clientType                ClientType          @default(CORPORATE)
  // ── Process 11: Renewal lifecycle ─────────────────────────
  renewalStatus             GroupRenewalStatus? // pipeline status
  supersededByGroupId       String? // points to the successor Group on renewal
  renewalNoticeDispatchedAt DateTime? // when the 60-day notice was sent
  priorPeriodReconciled     Boolean             @default(false) // block binding until settled
  // Funding mode — INSURED (default) or SELF_FUNDED
  fundingMode               FundingMode         @default(INSURED)
  // Self-funded admin fee config (ignored when fundingMode = INSURED)
  adminFeeMethod            AdminFeeMethod?
  adminFeeRate              Decimal? // KES flat (FLAT_PER_INSURED) or % (PCT_OF_CLAIMS)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  members            Member[]
  benefitTiers       GroupBenefitTier[]
  endorsements       Endorsement[]      @relation("EndorsementGroup")
  inboundTransfers   Endorsement[]      @relation("EndorsementToGroup")
  fundAdministrators User[]             @relation("FundAdminGroups")
  invoices           Invoice[]
  payments           Payment[]
  documents          Document[]
  activityLogs       ActivityLog[]
  quotations         Quotation[]
