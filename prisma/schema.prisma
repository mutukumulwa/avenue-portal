// ─── SELF-FUNDED SCHEME ACCOUNTS ─────────────────────────

// One account per self-funded group — tracks the fund balance
model SelfFundedAccount {
  currency String @default("UGX") // G3.5 multi-currency (base UGX)
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  groupId  String @unique
  group    Group  @relation(fields: [groupId], references: [id])

  balance        Decimal @default(0) @db.Decimal(14, 2)
  minimumBalance Decimal @default(0) @db.Decimal(14, 2)
  totalDeposited Decimal @default(0) @db.Decimal(14, 2)
  totalClaims    Decimal @default(0) @db.Decimal(14, 2)
  totalAdminFees Decimal @default(0) @db.Decimal(14, 2)

  // Categories currently on hold — no new claims approved against these
  heldCategories BenefitCategory[]

  // Track whether the period-end admin fee has been invoiced
  adminFeeInvoiceId String?

  periodStartDate DateTime
  periodEndDate   DateTime

  transactions FundTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// Ledger of every fund movement for a self-funded scheme
model FundTransaction {
  currency            String            @default("UGX") // G3.5 multi-currency (base UGX)
  id                  String            @id @default(cuid())
  tenantId            String
  tenant              Tenant            @relation(fields: [tenantId], references: [id])
  selfFundedAccountId String
  selfFundedAccount   SelfFundedAccount @relation(fields: [selfFundedAccountId], references: [id])

  type            FundTransactionType
  amount          Decimal             @db.Decimal(14, 2)
  balanceAfter    Decimal             @db.Decimal(14, 2)
  description     String
  referenceNumber String?
  claimId         String?
  claim           Claim?              @relation(fields: [claimId], references: [id])
  invoiceId       String?
  postedById      String?
  postedAt        DateTime            @default(now())

  @@index([tenantId])
  @@index([selfFundedAccountId])
  @@index([selfFundedAccountId, postedAt])
  @@index([selfFundedAccountId, type, postedAt])
  @@index([claimId])
}

// ─── KENYAN STATUTORY TAXES ──────────────────────────────

enum TaxType {
  STAMP_DUTY // KES 40 flat per policy — IRA requirement
  TRAINING_LEVY // 0.2% of basic premium — AKI training fund
  PHCF // 0.25% of basic premium — Post Hospital Care Fund
}

// Configurable tax rates per tenant (lets rates change without code changes)
model TaxRate {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  taxType       TaxType
  flatAmount    Decimal?  @db.Decimal(10, 2) // For STAMP_DUTY
  percentage    Decimal?  @db.Decimal(6, 4) // For percentage-based taxes (e.g. 0.2000 = 0.2%)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)

  @@unique([tenantId, taxType, effectiveFrom])
  @@index([tenantId])
}

// ─── APPROVAL MATRIX ─────────────────────────────────────

// Configures which role must approve a claim based on value and type
// ── Approval-matrix engine (Medvex spec §3.1 / gap G3.1) ───────────────
// Client-scoped, action-typed, currency-normalised, multi-level, SLA-timed,
// version-resolved authorization. Extended additively from the original thin
// (claims-only, single-role) model so existing rules/UI/claims path keep
// working: legacy rows are CLAIM_PAYMENT, clientId null (all clients), single
// step via requiredRole; new rules use actionType + ApprovalStep levels.
enum ApprovalActionType {
  CLAIM_PAYMENT
  PREAUTH_GOP
  LIMIT_OVERRIDE
  SCHEME_ACTIVATION
  COMMISSION_CHANGE
  MEMBER_ENDORSEMENT
  PROVIDER_TARIFF_CHANGE
  FUND_TOPUP
  WRITEOFF_REFUND
  AUTO_ADJ_POLICY_CHANGE // Claims Autopilot governed LIVE-policy activation (D15, F2.5)
}

model ApprovalMatrix {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  clientId String? // client scope; null = applies to all clients (operator default)
  client   Client? @relation(fields: [clientId], references: [id])

  actionType ApprovalActionType @default(CLAIM_PAYMENT)

  // Amount band. Stored in `currency`; the engine FX-normalises to base (UGX)
  // before comparing. claimValueMin/Max retained as the band columns.
  claimValueMin Decimal? // null = no lower bound
  claimValueMax Decimal? // null = no upper bound
  currency      String   @default("UGX")

  serviceType     ServiceType? // null = applies to all service types
  benefitCategory BenefitCategory? // null = applies to all categories

  requiredRole String // legacy single-step role (used when no ApprovalSteps)
  requiresDual Boolean @default(false) // legacy maker-checker flag

  // SLA / escalation defaults (per-step overrides on ApprovalStep)
  slaMinutes           Int?
  escalationTargetRole String?

  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps    ApprovalStep[]
  requests ApprovalRequest[]

  @@index([tenantId])
  @@index([tenantId, actionType])
  @@index([clientId])
}

// Sequential approval levels for a matrix rule (level 1 first, then 2, …).
model ApprovalStep {
  id       String         @id @default(cuid())
  matrixId String
  matrix   ApprovalMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)

  level                Int // 1-based sequence
  requiredRole         String
  slaMinutes           Int?
  escalationTargetRole String?

  @@unique([matrixId, level])
  @@index([matrixId])
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  CANCELLED
}

// Runtime approval workflow for a governed action. Records the resolved matrix
// (version-at-decision-time) and walks ApprovalStep levels with enforced SoD.
model ApprovalRequest {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  actionType ApprovalActionType
  entityType String // e.g. "Claim", "PreAuthorization"
  entityId   String

  amount     Decimal?
  currency   String          @default("UGX")
  baseAmount Decimal? // amount normalised to base (UGX) at request time
  matrixId   String? // resolved matrix rule (version in force at request time)
  matrix     ApprovalMatrix? @relation(fields: [matrixId], references: [id])

  status       ApprovalRequestStatus @default(PENDING)
  currentLevel Int                   @default(1)
  makerId      String

  // PR-025: the pending decision this request gates (the full decision input).
  // When the final level approves, the request APPLIES the decision itself —
  // a completed chain must never be a no-op.
  payload   Json?
  appliedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  decisions ApprovalDecision[]

  @@index([tenantId, status])
  @@index([clientId])
  @@index([entityType, entityId])
}

model ApprovalDecision {
  id        String          @id @default(cuid())
  requestId String
  request   ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  level       Int
  decidedById String
  decision    String // APPROVED | REJECTED
  notes       String?
  decidedAt   DateTime @default(now())

  @@index([requestId])
}

// ── Multi-currency reference (G3.5 schema-only; FX engine lands later) ──
model Currency {
  code     String  @id // ISO 4217, e.g. "UGX", "USD"
  name     String
  symbol   String?
  isActive Boolean @default(true)
}

model FxRate {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  baseCurrency  String // normalisation base, e.g. "UGX"
  quoteCurrency String
  rate          Decimal // 1 quote = `rate` base
  source        String?

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)

  @@index([tenantId, baseCurrency, quoteCurrency])
}

// ── Auto-adjudication policy (Medvex spec §3.7 / gap G3.7) ──────────────
// Client-configurable, versioned criteria for auto-approving clean low-risk
// claims without a human touch. Everything else routes to review with the
// failing gate named. Never-delete (effective dating = versioning).
model AutoAdjudicationPolicy {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  clientId String? // null = operator default; set = per-client override
  client   Client? @relation(fields: [clientId], references: [id])

  enabled                  Boolean  @default(true)
  maxAutoApproveAmount     Decimal? // ceiling in `currency`; above → route. null = no ceiling
  currency                 String   @default("UGX")
  requireCleanFraud        Boolean  @default(true) // no open fraud flag to auto-approve
  requirePreauthWhenNeeded Boolean  @default(true)

  // ── Claims Autopilot governed policy (F2.4, §9.6) ─────────────────────────
  // mode defaults OFF and status DRAFT so NO existing/new row is implicitly LIVE
  // (D1/D2). LIVE requires an APPROVED status + finite positive ceiling + the
  // required gates on + explicit inclusions (validated in claim-autopilot/policy.ts).
  name                     String?
  version                  Int                          @default(1)
  mode                     AutoAdjudicationMode         @default(OFF)
  status                   AutoAdjudicationPolicyStatus @default(DRAFT)
  allowAutoPartial         Boolean                      @default(false) // D4 opt-in
  allowedSources           ClaimSource[]                @default([])
  allowedServiceTypes      ServiceType[]                @default([])
  allowedBenefitCategories BenefitCategory[]            @default([])
  allowedProviderTiers     String[]                     @default([])
  maxClaimAgeDays          Int?
  requireAllLinesPriced    Boolean                      @default(true)
  requireDocumentsComplete Boolean                      @default(true)
  requireEligibilityClear  Boolean                      @default(true)
  createdById              String?
  approvalRequestId        String?
  approvedById             String?
  approvedAt               DateTime?
  deactivatedById          String?
  deactivationReason       String?

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, clientId])
  @@index([tenantId, isActive])
}

// ── Offline-first / store-and-forward (Medvex spec §4 / gap G4) ─────────
// Server-side provenance for the offline point-of-care rail: a durable buffer
// of client-captured operations (idempotent by opKey), soft benefit
// reservations, and time-boxed eligibility snapshots. The client PWA holds the
// mirror (IndexedDB); the sync-reconcile queue reconciles on reconnect.
enum SyncOperationState {
  PENDING // received, not yet reconciled
  SYNCED // reconciled and applied
  CONFLICT // needs review (e.g. insufficient balance) — never silently dropped
  REJECTED // authoritatively rejected (with reason)
}

model SyncOperation {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  clientUuid String // client-generated record UUID
  opKey      String // idempotency key (client UUID + op) — unique per tenant
  entityType String // "CheckIn" | "PreAuth" | "Claim" | "Image"
  payload    Json
  deviceId   String?
  capturedAt DateTime // when captured offline at point of care
  syncedAt   DateTime?

  state          SyncOperationState @default(PENDING)
  conflictReason String?

  // Offline work authorization (WP-B1/B4): the agent-issued code this op was
  // captured under. Null for pre-code legacy ops; invalid codes ⇒ CONFLICT.
  offlineAuthId String?
  offlineAuth   OfflineWorkAuthorization? @relation(fields: [offlineAuthId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, opKey])
  @@index([tenantId, state])
  @@index([tenantId, entityType])
  @@index([offlineAuthId])
}

model OfflineReservation {
  id              String  @id @default(cuid())
  tenantId        String
  tenant          Tenant  @relation(fields: [tenantId], references: [id])
  memberId        String
  benefitConfigId String?
  amount          Decimal
  currency        String  @default("UGX")
  reason          String? // provisional claim / pre-auth hold
  syncOperationId String? // the offline op that created this hold

  state     SyncOperationState @default(PENDING)
  expiresAt DateTime // time-boxed soft hold
  createdAt DateTime           @default(now())

  @@index([tenantId, memberId])
  @@index([tenantId, state])
}

model EligibilitySnapshot {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  memberId  String
  clientId  String?
  active    Boolean
  balances  Json // benefit balances net of soft reservation, for offline cache
  tariffRef String? // version/pointer of the price list captured with it

  capturedAt DateTime @default(now())
  validUntil DateTime // shorter for near-limit / high-risk members

  @@index([tenantId, memberId])
}

// ─── OFFLINE WORK AUTHORIZATION (WP-B1, TPA_FEEDBACK_WORKPLAN.md §B) ──────
// A facility that loses connectivity calls the claims agent; the agent issues
// a short time-boxed code over the phone / SMS (off-system by design). The
// code unlocks offline capture at that facility and every synced operation is
// traceable back to it.

enum OfflineAuthStatus {
  ACTIVE
  EXPIRED
  REVOKED
  EXHAUSTED // maxOperations reached
}

model OfflineWorkAuthorization {
  id            String            @id @default(cuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  providerId    String // facility the code is issued to
  provider      Provider          @relation(fields: [providerId], references: [id])
  branchId      String? // optional branch scope
  branch        ProviderBranch?   @relation(fields: [branchId], references: [id])
  code          String // short human-readable, e.g. OWA-7F3K2M
  issuedById    String // claims agent who took the call
  issuedBy      User              @relation("OfflineAuthIssuer", fields: [issuedById], references: [id])
  reason        String? // e.g. "fibre cut at facility" — captured on the call
  contactName   String? // who called from the facility
  contactPhone  String?
  validFrom     DateTime          @default(now())
  validUntil    DateTime // time-boxed, default 48 h
  maxOperations Int? // optional cap on ops synced under this code
  status        OfflineAuthStatus @default(ACTIVE)
  revokedById   String?
  revokedAt     DateTime?
  packId        String? // last OfflineDataPack served under this authorization

  syncOperations SyncOperation[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, providerId, status])
  @@index([tenantId, status])
}

// Facility offline data pack (WP-B3, decision D3): the MINIMUM data a facility
// needs to run its day offline — member roster (number/name/status), benefit
// balances, tariff excerpt. Stored and served ONLY as an AES-256-GCM envelope;
// the key is HKDF-derived from the work code + server secret and delivered
// separately, so a stolen pack file alone is useless.
model OfflineDataPack {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])
  generatedAt DateTime @default(now())
  validUntil  DateTime
  memberCount Int
  tariffRef   String? // contract/version pinned into the pack
  ciphertext  Bytes // AES-256-GCM(roster + balances + tariff excerpt)
  iv          Bytes
  authTag     Bytes
  keyVersion  Int      @default(1) // server-secret rotation
  sizeBytes   Int?

  @@index([tenantId, providerId, generatedAt])
}

// ─── PACKAGES & BENEFITS ────────────────────────────────
enum PackageType {
  INDIVIDUAL
  FAMILY
  GROUP
  CORPORATE
}

enum PackageStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Package {
  id                 String        @id @default(cuid())
  tenantId           String
  tenant             Tenant        @relation(fields: [tenantId], references: [id])
  name               String // "Medvex Essential"
  description        String?
  type               PackageType   @default(GROUP)
  annualLimit        Decimal // Overall annual limit in KES
  perVisitLimit      Decimal?
  contributionAmount Decimal // Per-member annual contribution
  status             PackageStatus @default(DRAFT)
  minAge             Int           @default(0)
  maxAge             Int           @default(65)
  dependentMaxAge    Int           @default(24)
  exclusions         String[] // List of excluded conditions
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  versions                PackageVersion[]
  currentVersionId        String?                  @unique
  currentVersion          PackageVersion?          @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  groups                  Group[]
  members                 Member[]
  benefitTiers            GroupBenefitTier[]
  coContributionRules     CoContributionRule[]
  annualCoContributionCap AnnualCoContributionCap?

  @@index([tenantId])
}

model PackageVersion {
  id              String          @id @default(cuid())
  packageId       String
  package         Package         @relation(fields: [packageId], references: [id])
  versionNumber   Int
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  benefits        BenefitConfig[]
  facilityAccess  String[] // Provider IDs or "ALL_MEDVEX" / "ALL_NETWORK"
  pricingModelUrl String? // URL to uploaded pricing model (Excel/Python)
  pricingConfig   Json? // Structured pricing parameters
  createdAt       DateTime        @default(now())

  currentForPackage Package?                     @relation("CurrentVersion")
  groups            Group[]
  members           Member[]
  sharedLimitGroups SharedLimitGroup[]
  eligibilityRules  PackageProviderEligibility[]

  @@unique([packageId, versionNumber])
}

enum BenefitCategory {
  INPATIENT
  OUTPATIENT
  MATERNITY
  DENTAL
  OPTICAL
  MENTAL_HEALTH
  CHRONIC_DISEASE
  SURGICAL
  AMBULANCE_EMERGENCY
  LAST_EXPENSE
  WELLNESS_PREVENTIVE
  REHABILITATION
  CUSTOM
}

model BenefitRider {
  code        String   @id // e.g., IP-HIV, OP-DNTL
  description String
  type        String // INPATIENT | OUTPATIENT
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// How a benefit line is paid to providers (WP-F1, decision D8). FFS prices
// each line off the contract; CAPITATION lines are covered by the provider's
// capitation pool (no per-line payable); HYBRID splits by service tier via
// fundingOverrides.
enum FundingModelType {
  FEE_FOR_SERVICE
  CAPITATION
  HYBRID
}

model BenefitConfig {
  id                 String          @id @default(cuid())
  packageVersionId   String
  packageVersion     PackageVersion  @relation(fields: [packageVersionId], references: [id])
  category           BenefitCategory
  customCategoryName String? // If category == CUSTOM
  annualSubLimit     Decimal // KES
  perVisitLimit      Decimal?
  copayPercentage    Decimal         @default(0) // e.g., 10 = 10%
  // Cost-share (G9.1) — distinct from copay: co-insurance is the member's % of
  // the cost AFTER the annual deductible is met. deductibleAmount is the annual
  // member-paid threshold before the plan pays. Both default 0 (off).
  coInsurancePct     Decimal         @default(0) // e.g. 20 = member pays 20% post-deductible
  deductibleAmount   Decimal         @default(0) // annual member-paid threshold
  // Funding model (WP-F1/D8): default FFS keeps existing behaviour. HYBRID
  // uses fundingOverrides: [{ tier: ServiceTier, model: FundingModelType }],
  // validated in the service layer.
  fundingModel       FundingModelType @default(FEE_FOR_SERVICE)
  fundingOverrides   Json?
  waitingPeriodDays  Int             @default(0)
  notes              String?
  exclusions         String[]

  benefitUsages     BenefitUsage[]
  sharedLimitGroups BenefitConfigSharedLimit[]

  @@index([packageVersionId])
}

enum LimitScope {
  MEMBER
  FAMILY
}

model SharedLimitGroup {
  id               String         @id @default(cuid())
  packageVersionId String
  packageVersion   PackageVersion @relation(fields: [packageVersionId], references: [id])
  name             String
  limitAmount      Decimal        @db.Decimal(14, 2)
  appliesTo        LimitScope     @default(FAMILY)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  benefitConfigs BenefitConfigSharedLimit[]

  @@index([packageVersionId])
}

model BenefitConfigSharedLimit {
  benefitConfigId    String
  benefitConfig      BenefitConfig    @relation(fields: [benefitConfigId], references: [id])
  sharedLimitGroupId String
  sharedLimitGroup   SharedLimitGroup @relation(fields: [sharedLimitGroupId], references: [id])
  createdAt          DateTime         @default(now())

  @@id([benefitConfigId, sharedLimitGroupId])
  @@index([sharedLimitGroupId])
}

model BenefitUsage {
  id               String        @id @default(cuid())
  memberId         String
  member           Member        @relation(fields: [memberId], references: [id])
  benefitConfigId  String
  benefitConfig    BenefitConfig @relation(fields: [benefitConfigId], references: [id])
  periodStart      DateTime // Start of the benefit period (usually enrollment anniversary)
  periodEnd        DateTime
  amountUsed       Decimal       @default(0)
  activeHoldAmount Decimal       @default(0) @db.Decimal(14, 2) // sum of active BenefitHold records
  deductibleMet    Decimal       @default(0) @db.Decimal(14, 2) // member deductible paid this period (G9.1)
  claimCount       Int           @default(0)
  lastUpdated      DateTime      @default(now())

  @@unique([memberId, benefitConfigId, periodStart])
  @@index([memberId])
}

// ─── ENDORSEMENTS ───────────────────────────────────────
// Endorsements track mid-term changes to a group's membership

enum EndorsementType {
  MEMBER_ADDITION // New member joins mid-term
  MEMBER_DELETION // Member exits mid-term
  DEPENDENT_ADDITION // New dependent added
  DEPENDENT_DELETION // Dependent removed
  PACKAGE_UPGRADE // Member/group moves to higher package
  PACKAGE_DOWNGRADE // Member/group moves to lower package
  AGE_BAND_CHANGE // Age reclassification
  BENEFIT_MODIFICATION // Change in benefits (e.g., maternity rider added)
  SALARY_CHANGE // If contribution is salary-based
  GROUP_DATA_CHANGE // Contact info, payment terms change
  TIER_CHANGE // Member moved between benefit tiers within the same group
  SCHEME_TRANSFER // Member moves to a different group entirely
  CORRECTION // Error correction
  BENEFICIARY_UPDATE // Beneficiary designation change
  BANKING_DETAILS_UPDATE // Member/group banking/M-Pesa details
  MID_TERM_RATE_CHANGE // Scheme contribution rate change between renewals
}

enum EndorsementStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  APPLIED // Changes have been applied to the system
  CANCELLED
}

model Endorsement {
  id                String            @id @default(cuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  endorsementNumber String // e.g., END-2025-00001
  groupId           String
  group             Group             @relation("EndorsementGroup", fields: [groupId], references: [id])
  type              EndorsementType
  status            EndorsementStatus @default(DRAFT)
  effectiveDate     DateTime
  requestedDate     DateTime          @default(now())
  requestedBy       String? // User ID or "BROKER" or "SYSTEM"

  // The member(s) affected
  memberId String? // For member-level endorsements
  member   Member? @relation("EndorsementMember", fields: [memberId], references: [id])

  // SCHEME_TRANSFER: destination group
  toGroupId       String?
  toGroup         Group?            @relation("EndorsementToGroup", fields: [toGroupId], references: [id])
  // TIER_CHANGE: destination tier within same group
  toBenefitTierId String?
  toBenefitTier   GroupBenefitTier? @relation("EndorsementTier", fields: [toBenefitTierId], references: [id])

  // Change details stored as structured JSON
  // Examples:
  // MEMBER_ADDITION: { firstName, lastName, dob, gender, idNumber, relationship, dependents[] }
  // MEMBER_DELETION: { reason, lastDay, refundEligible }
  // PACKAGE_UPGRADE: { fromPackageId, toPackageId }
  changeDetails Json

  // Financial impact
  proratedAmount  Decimal? // Pro-rata premium adjustment (+ = additional, - = refund)
  previousPremium Decimal? // What the group was paying before
  newPremium      Decimal? // What they'll pay after
  premiumDelta    Decimal? // Difference

  // Approval
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  rejectionReason String?

  // Application
  appliedAt DateTime?
  appliedBy String?

  // ── Process 7: Amendment enrichments ──────────────────────
  beforeSnapshot       Json? // full membership state before amendment
  afterSnapshot        Json? // full membership state after (populated on approval)
  proRataCalculationId String? // FK to ProRataCalculation
  makerId              String? // user who initiated (maps to requestedBy FK)
  approverId           String? // user who approved
  backDated            Boolean @default(false)
  overrideRecordId     String? // required when backDated=true
  requiresAssessment   Boolean @default(false)
  assessmentDecisionId String? // UnderwritingDecision.id if re-assessment done

  maker    User? @relation("EndorsementMaker", fields: [makerId], references: [id])
  approver User? @relation("EndorsementApprover", fields: [approverId], references: [id])

  proRataCalculation ProRataCalculation?

  documents    Document[]
  activityLogs ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([tenantId, endorsementNumber])
  @@index([tenantId])
  @@index([groupId])
  @@index([groupId, status])
  @@index([tenantId, status])
}

enum ProRataType {
  CHARGE
  CREDIT
  ZERO
}

model ProRataCalculation {
  id                   String      @id @default(cuid())
  tenantId             String
  endorsementId        String      @unique
  previousContribution Decimal     @db.Decimal(19, 4)
  newContribution      Decimal     @db.Decimal(19, 4)
  periodStartDate      DateTime
  periodEndDate        DateTime
  effectiveDate        DateTime
  daysRemaining        Int
  totalDaysInPeriod    Int
  prorataFactor        Decimal     @db.Decimal(10, 8) // daysRemaining / totalDaysInPeriod
  adjustmentAmount     Decimal     @db.Decimal(19, 4) // positive=charge, negative=credit
  adjustmentType       ProRataType
  computedAt           DateTime    @default(now())

  endorsement Endorsement @relation(fields: [endorsementId], references: [id])
}

// ─── CLAIMS ─────────────────────────────────────────────
enum ClaimStatus {
  INCURRED // Liability known before paper arrives (e.g. discharge notification)
  RECEIVED // Claim documents received from provider
  CAPTURED // Data entry complete — awaiting adjudication
  UNDER_REVIEW // Medical officer / claims officer reviewing
  APPROVED
  PARTIALLY_APPROVED
  DECLINED
  PAID
  APPEALED
  APPEAL_APPROVED
  APPEAL_DECLINED
  VOID
}

enum ClaimSource {
  MANUAL // Entered by admin
  REIMBURSEMENT // Member paid provider directly — insurer reimburses member
  PREAUTH // Converted from pre-authorization
  SMART // Received via SMART integration
  SLADE360 // Received via Slade360 EDI
  HMS // Received from hospital HMS
  BATCH // Batch upload from facility
  OFFLINE_SYNC // Captured offline at point of care, store-and-forward synced (G4)
  USSD // Captured via USSD session (G4.5)
  SMS // Captured via SMS (G4.5)
}

enum ServiceType {
  OUTPATIENT
  INPATIENT
  DAY_CASE
  EMERGENCY
}

model Claim {
  currency         String            @default("UGX") // G3.5 multi-currency (base UGX)
  id               String            @id @default(cuid())
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  claimNumber      String // e.g., CLM-2025-00001
  invoiceNumber    String? // Provider's own invoice number — unique per provider
  memberId         String
  member           Member            @relation(fields: [memberId], references: [id])
  providerId       String
  provider         Provider          @relation(fields: [providerId], references: [id])
  // Branch at which the service was rendered (digital-contract spec §5.2/§8.1) —
  // required at capture for multi-branch providers so branch-scoped contracts and
  // rates can match. Null for legacy/single-branch providers.
  providerBranchId String?
  providerBranch   ProviderBranch?   @relation(fields: [providerBranchId], references: [id])
  // Attached pre-authorizations (WP-C1/D4): a claim may carry several PAs
  // alongside BAU lines; the FK lives on PreAuthorization.claimId.
  preauths         PreAuthorization[]
  // Filing case (WP-D1/D5): set when this claim was assembled from a clinical
  // case at closure. Non-unique by design — one-case-many-claims stays open.
  caseId           String?
  case             ClinicalCase?     @relation(fields: [caseId], references: [id])
  // ── IPL-001 interim/periodic inpatient settlement ────────────────────────
  // A case now files MANY claims: interim "slices" cut at each Friday cut-off
  // while the admission stays open, then one final claim for the residual at
  // closure. These fields describe a case-derived claim; they are null for
  // ordinary (non-case) claims.
  caseSliceSeq     Int? // 1,2,3… assigned in cut order within the case (final claim = last seq)
  isInterimBill    Boolean            @default(false) // true = slice cut on an OPEN case; false = final/ordinary
  sliceCutoffAt    DateTime? // frozen cut-off instant for an interim slice
  sliceServiceFrom DateTime? // earliest entry date in the slice
  sliceServiceTo   DateTime? // latest entry date in the slice
  sliceEntries     CaseServiceEntry[] @relation("SliceEntries") // entries frozen into this claim
  source           ClaimSource       @default(MANUAL)
  serviceType      ServiceType
  dateOfService    DateTime
  admissionDate    DateTime? // For inpatient
  dischargeDate    DateTime?
  lengthOfStay     Int? // Calculated days
  attendingDoctor  String?

  // Diagnosis — stored as JSON array of { code, description, isPrimary }
  diagnoses Json // [{ icdCode: "E11.9", description: "Type 2 diabetes", isPrimary: true }]

  // Procedures — stored as JSON array of { code, description, quantity, unitCost, totalCost }
  procedures Json // [{ cptCode: "99213", description: "Office visit", qty: 1, unitCost: 2500, total: 2500 }]

  // Financial
  billedAmount    Decimal
  approvedAmount  Decimal @default(0)
  copayAmount     Decimal @default(0)
  excessAmount    Decimal @default(0) // Amount exceeding benefit limit
  paidAmount      Decimal @default(0)
  memberLiability Decimal @default(0) // Total member pays (copay + excess)

  // ── OBS-2 Ticket 5: FX snapshot pinned at decision time ──────────────────
  // For a non-base (≠ UGX) claim, the approved/billed amounts are normalised to
  // base currency at the decision-date rate and stored so GL, settlement and
  // reports never re-infer a historical rate. UGX claims keep base == txn at
  // rate 1. A non-base claim with no in-force rate fails closed before approval.
  baseCurrency       String    @default("UGX")
  approvedBaseAmount Decimal   @default(0) @db.Decimal(19, 4)
  billedBaseAmount   Decimal?  @db.Decimal(19, 4)
  fxRateToBase       Decimal?  @db.Decimal(19, 8)
  fxRateDate         DateTime?

  // Benefit allocation
  benefitCategory BenefitCategory
  benefitUsageId  String?

  // ── Process 9 adjudication extensions ────────────────────
  contractedRate        Decimal? @db.Decimal(14, 2) // looked-up from ProviderTariff at adjudication
  contractedVariancePct Decimal? @db.Decimal(5, 4) // (billed - contracted) / contracted

  // ── Digital-contract engine provenance (spec §6.1/§8.2) ──
  // The contract family and version that priced this claim, pinned at first
  // adjudication (re-pin logged). `assignedQueue` names the §8.5 manual-review
  // queue when the claim cannot auto-process.
  contractId          String?
  contract            ProviderContract? @relation(fields: [contractId], references: [id])
  contractVersionId   String?
  contractFamilyIds   String[]          @default([]) // parent + sibling addenda ids merged at match
  assignedQueue       String? // NO_CONTRACT | RATE_MISSING | SERVICE_NOT_MAPPED | ... (§8.5)
  avgCostPoolId       String? // AVERAGE_COST_POOL tag — claim belongs to a reconciliation pool (§6.4, spec P5/P6)
  adjudicatorId       String? // FK to User who adjudicated
  seniorAdjudicatorId String? // FK to User who gave senior approval
  appealReviewerId    String? // must differ from adjudicatorId
  settlementBatchId   String? // FK to ProviderSettlementBatch

  adjudicator       User?                    @relation("ClaimAdjudicator", fields: [adjudicatorId], references: [id])
  seniorAdjudicator User?                    @relation("ClaimSeniorAdjudicator", fields: [seniorAdjudicatorId], references: [id])
  settlementBatch   ProviderSettlementBatch? @relation(fields: [settlementBatchId], references: [id])

  // ── Auto-adjudication provenance (G3.7) — a routed claim always names why ──
  autoAdjDecision    String? // AUTO_APPROVE | ROUTE
  autoAdjFailingGate String? // named failing gate when routed
  autoAdjPolicyId    String? // resolved AutoAdjudicationPolicy id (null = built-in default)
  autoAdjudicatedAt  DateTime?

  // ── Claims Autopilot intake/processing provenance (F2.3, §9.5) ────────────
  // Populated from terminal processing results; the legacy autoAdj* fields above
  // are kept during migration for compatibility.
  intakeSchemaVersion           String?
  claimRevision                 Int                   @default(1)
  strongEventFingerprint        String? // authoritative event id (unique per tenant; multiple nulls allowed)
  suspectedDuplicateFingerprint String? // non-unique content signature
  processingState               ClaimProcessingState?
  processingRouteCode           String?
  processingRuns                ClaimProcessingRun[]

  // ── Cost-share components (G9.1) — deductible + co-insurance, distinct from copay ──
  costShareDeductible  Decimal @default(0) @db.Decimal(14, 2)
  costShareCoInsurance Decimal @default(0) @db.Decimal(14, 2)

  // Status & workflow
  status             ClaimStatus @default(RECEIVED)
  assignedReviewerId String?
  assignedReviewer   User?       @relation("ClaimReviewer", fields: [assignedReviewerId], references: [id])
  receivedAt         DateTime    @default(now())
  reviewStartedAt    DateTime?
  decidedAt          DateTime?
  paidAt             DateTime?
  turnaroundDays     Int? // Calculated: decidedAt - receivedAt

  // Decline info
  declineReasonCode String? // PREEXISTING, EXCLUSION, BENEFIT_EXHAUSTED, WAITING_PERIOD, INVALID_DOCS, NON_COVERED_FACILITY, FRAUD_SUSPECTED, OTHER
  declineNotes      String?

  // Appeal info
  appealDate      DateTime?
  appealNotes     String?
  appealDecision  String?
  appealDecidedAt DateTime?

  // Reimbursement — member paid provider directly; insurer pays member back
  isReimbursement         Boolean   @default(false)
  reimbursementBankName   String?
  reimbursementAccountNo  String?
  reimbursementMpesaPhone String?
  reimbursedAt            DateTime?

  // Integration references
  smartClaimRef    String? // SMART claim reference
  slade360ClaimRef String? // Slade360 eClaim reference
  externalRef      String? // Any external reference / BB2-DEF-03 B2B idempotency key (unique per tenant+provider)

  hasException     Boolean           @default(false)
  claimLines       ClaimLine[]
  documents        Document[]
  adjudicationLogs AdjudicationLog[]
  exceptionLogs    ExceptionLog[]    @relation("ClaimExceptions")
  paymentVoucherId String?
  paymentVoucher   PaymentVoucher?   @relation(fields: [paymentVoucherId], references: [id])

  fraudAlerts               ClaimFraudAlert[]
  coContributionTransaction CoContributionTransaction?
  fundTransactions          FundTransaction[]
  reimbursementRequest      ReimbursementRequest?
  intakeReceipts            ClaimIntakeReceipt[]
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt

  @@unique([tenantId, claimNumber])
  // Provider-scoped invoice uniqueness — prevents same provider submitting same invoice twice
  @@unique([providerId, invoiceNumber])
  // BB2-DEF-03: idempotent B2B retries — a facility replaying the same externalRef
  // returns the original claim (NULLs are distinct in Postgres, so untagged claims
  // are unaffected).
  @@unique([tenantId, providerId, externalRef])
  // Claims Autopilot (§9.5): one claim per authoritative strong event fingerprint.
  // Postgres treats NULLs as distinct, so unlabelled claims are unaffected.
  @@unique([tenantId, strongEventFingerprint])
  @@index([tenantId, suspectedDuplicateFingerprint])
  // Double-capture detection index — (provider, member, date, category) lookups at adjudication
  @@index([tenantId, providerId, memberId, dateOfService, benefitCategory])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([memberId])
  @@index([providerId])
}

enum ClaimLineCategory {
  CONSULTATION
  LABORATORY
  PHARMACY
  IMAGING
  PROCEDURE
  OTHER
}

enum ClaimLineDecision {
  APPROVED
  APPROVED_WITH_ADJUSTMENT
  DECLINED
}

enum SettlementStatus {
  PENDING
  MAKER_SUBMITTED
  CHECKER_APPROVED
  SETTLED
  REJECTED
}

// Drug-level exclusion control (Medvex spec §H.2 / gap G9.5). An excluded-drug
// list per client and/or package, enforced at adjudication against
// ClaimLine.drugCode. Never-delete (effective dating).
model DrugExclusion {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  clientId  String? // null = applies to all clients
  client    Client? @relation(fields: [clientId], references: [id])
  packageId String? // null = applies to all packages

  drugCode String // ATC/NDC or local register code
  drugName String?
  reason   String?

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([tenantId, drugCode])
  @@index([tenantId, clientId])
}

// Reason-code catalog (spec §5.13/§10.1) — not an enum so payers/tenants can
// extend. Seeded with the CON/ELG/SVC/PRC/LIM/EXC/AUTH/DOC/SUB/DUP/MAN taxonomy.
enum ReasonSeverity {
  REJECT
  SHORTFALL
  PEND
  INFO
}

model AdjudicationReasonCode {
  id                             String         @id @default(cuid())
  tenantId                       String? // null = platform-shipped default; set = tenant override/extension
  tenant                         Tenant?        @relation(fields: [tenantId], references: [id])
  code                           String // e.g. "PRC-001"
  category                       String // Contract | Eligibility | Service | Pricing | Limits | Exclusion | Pre-auth | Documents | Submission | Duplicate | Manual
  internalDescription            String
  providerDescription            String
  memberDescription              String
  contractRuleRefType            String? // which rule type triggers it (Tariff | Package | PreauthRule | ...)
  defaultSeverity                ReasonSeverity @default(REJECT)
  remedy                         String?
  resubmissionAllowed            Boolean        @default(false)
  overrideAllowed                Boolean        @default(false)
  allowedOverrideTypes           String[]       @default([]) // OverrideType names
  requiredDocsForReconsideration String[]       @default([])
  escalationRoute                String? // queue name (§8.5)
  isActive                       Boolean        @default(true)
  createdAt                      DateTime       @default(now())
  updatedAt                      DateTime       @updatedAt

  claimLines ClaimLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([code])
}

model ClaimLine {
  id                   String             @id @default(cuid())
  claimId              String
  claim                Claim              @relation(fields: [claimId], references: [id])
  lineNumber           Int
  serviceCategory      ClaimLineCategory  @default(CONSULTATION)
  description          String
  icdCode              String? // Diagnosis code for this line (may differ from claim header)
  cptCode              String?
  drugCode             String? // ATC/NDC or local drug-register code (G9.2/G9.5)
  quantity             Int                @default(1)
  unitCost             Decimal
  billedAmount         Decimal
  tariffRate           Decimal? // Contracted rate from provider tariff
  approvedAmount       Decimal            @default(0)
  isException          Boolean            @default(false) // Manual override applied
  exceptionRef         String? // Reference code for exception
  notes                String?
  // Process 9: per-line adjudication decision
  adjudicationDecision ClaimLineDecision?
  adjustedAmount       Decimal?           @db.Decimal(14, 2) // approved amount when adjusted
  adjustmentReason     String?
  declineReason        String?

  // ── Digital-contract engine per-line provenance & amounts (spec §5.13/§6.4) ──
  serviceCategoryId    String?
  serviceCategoryRef   ServiceCategory?        @relation(fields: [serviceCategoryId], references: [id])
  contractId           String? // family/contract that priced the line
  contractVersionId    String? // version effective on the service date
  matchedRuleType      String? // CONTRACT_TARIFF | STANDALONE_TARIFF | UNLISTED_* | EXCLUDED | NO_CONTRACT | ...
  matchedRuleId        String? // the tariff/rule id that priced it
  payableSource        String? // human label of what produced the payable
  reasonCodeId         String?
  reasonCode           AdjudicationReasonCode? @relation(fields: [reasonCodeId], references: [id])
  contractedAmount     Decimal?                @db.Decimal(14, 2) // qty × contracted unit
  shortfallAmount      Decimal                 @default(0) @db.Decimal(14, 2) // claimed − payable absorbed by provider
  disallowedAmount     Decimal                 @default(0) @db.Decimal(14, 2) // components rejected outright
  memberLiability      Decimal                 @default(0) @db.Decimal(14, 2) // only where balance-billing permits
  payerLiability       Decimal                 @default(0) @db.Decimal(14, 2)
  providerWriteOff     Decimal                 @default(0) @db.Decimal(14, 2)
  externalRebateAmount Decimal?                @db.Decimal(14, 2) // NET_OF_EXTERNAL (Phase 3)
  quantityApproved     Int? // payable quantity after caps
  ruleTrace            Json? // machine-readable per-stage engine trace (§6)

  @@index([claimId])
  @@index([contractId])
  @@index([reasonCodeId])
  @@index([serviceCategoryId])
}

model AdjudicationLog {
  id         String   @id @default(cuid())
  claimId    String
  claim      Claim    @relation(fields: [claimId], references: [id])
  userId     String
  action     String // RECEIVED, REVIEW_STARTED, APPROVED, DECLINED, MORE_INFO_REQUESTED, ESCALATED, HELD, PAID, APPEALED, APPEAL_DECIDED
  fromStatus String?
  toStatus   String
  amount     Decimal? // If amount was adjusted
  notes      String?
  createdAt  DateTime @default(now())

  @@index([claimId])
}

// ─── PRE-AUTHORIZATION ──────────────────────────────────
enum PreauthStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DECLINED
  EXPIRED // Approved but validity period passed without use
  ATTACHED // Approved and attached to a claim awaiting decision (WP-C1/D4)
  UTILISED // Attached claim was decided — PA consumed
  CONVERTED_TO_CLAIM // Legacy 1:1 conversion — historical rows only, no longer produced
  CANCELLED
}

model PreAuthorization {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  preauthNumber String // e.g., PA-2025-00001
  memberId      String
  member        Member        @relation(fields: [memberId], references: [id])
  providerId    String
  provider      Provider      @relation(fields: [providerId], references: [id])
  submittedBy   String // "MEMBER", "PROVIDER", "ADMIN", "BROKER"
  status        PreauthStatus @default(SUBMITTED)

  // Clinical info
  diagnoses             Json // Same format as Claim.diagnoses
  procedures            Json // Same format as Claim.procedures
  estimatedCost         Decimal
  clinicalNotes         String?
  serviceType           ServiceType @default(OUTPATIENT)
  expectedDateOfService DateTime?

  // Benefit check at time of submission
  benefitCategory  BenefitCategory
  benefitRemaining Decimal? // Snapshot of remaining benefit at time of request

  // Approval details
  approvedAmount Decimal?
  // PR-022: cover consumed so far by decided claims. A PA is only UTILISED
  // when utilisedAmount reaches approvedAmount; a smaller claim consumes its
  // share and the PA (with its remaining hold) stays available for the episode.
  utilisedAmount Decimal   @default(0) @db.Decimal(14, 2)
  approvedBy     String?
  approvedAt     DateTime?
  validFrom      DateTime? // Validity period start
  validUntil     DateTime? // Validity period end (e.g., 30 days from approval)
  // Guarantee of Payment artefact (G5.5): issued on approval within financial
  // limits. approvedAmount is the guaranteed (limit-capped) amount; validUntil
  // the window. gopNumber references the GOP for the provider.
  gopNumber      String? // e.g. GOP-2026-00001
  gopIssuedAt    DateTime?
  // IP-DEF-01: the reviewer's optional note on APPROVAL. The pre-fix code wrote
  // this field behind an `as never` cast while the column did not exist — any
  // approval with notes crashed with a raw Prisma validation error.
  reviewNotes    String?

  // Decline details
  declineReasonCode String?
  declineNotes      String?
  declinedBy        String?
  declinedAt        DateTime?

  // Escalation — if pending past threshold, auto-notify next approver
  escalationThresholdHours Int? // null = no escalation configured
  escalatedAt              DateTime?
  escalatedToId            String?
  escalatedTo              User?     @relation("PreauthEscalation", fields: [escalatedToId], references: [id])

  // Attachment to a claim (WP-C1/D4): a PA attaches to at most one claim; a
  // claim may carry many PAs alongside BAU service lines.
  claimId     String?
  claim       Claim?    @relation(fields: [claimId], references: [id])
  attachedAt  DateTime?
  convertedAt DateTime? // legacy 1:1 conversion timestamp — historical rows only
  // Open-case linkage (WP-D1): PA accrues on the case until closure re-points
  // it at the filed claim.
  caseId      String?
  case        ClinicalCase? @relation(fields: [caseId], references: [id])

  // ── Process 8 extensions ──────────────────────────────────
  isEmergency         Boolean   @default(false)
  slaType             String? // OUTPATIENT | INPATIENT_PREADMISSION | EMERGENCY
  slaDeadlineAt       DateTime?
  slaBreachedAt       DateTime?
  parentPreAuthId     String? // for mid-treatment amendments — links to parent PA
  estimatedComponents Json? // breakdown for multi-component PAs (theatre + ICU + ward)
  autoDecisionLog     Json? // gate-by-gate result from auto-decision pipeline
  fraudFlags          Json? // fraud rule firings at decision time

  benefitHold BenefitHold?

  documents    Document[]
  activityLogs ActivityLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([tenantId, preauthNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, createdAt])
  @@index([memberId])
  @@index([claimId])
}

// ─── CASE MANAGEMENT (WP-D1, TPA_FEEDBACK_WORKPLAN.md §D) ────────────────
// A clinical episode container: services, pre-auths, and letters of
// undertaking accrue against an OPEN case (e.g. an inpatient stay) and are
// filed as a single claim at closure. One case → one claim is enforced in the
// service layer (the FK lives on Claim.caseId, non-unique, so one-case-many-
// claims — pregnancy + newborn — stays open as a future path with no migration).

enum CaseStatus {
  OPEN
  PENDING_CLOSURE
  CLOSED_FILED
  CANCELLED
}

enum CaseType {
  INPATIENT_ADMISSION
  OUTPATIENT_EPISODE
  MATERNITY
  DAY_CASE
  CHRONIC_CYCLE
}

model ClinicalCase {
  id                    String          @id @default(cuid())
  tenantId              String
  tenant                Tenant          @relation(fields: [tenantId], references: [id])
  caseNumber            String // e.g. CASE-2026-00001
  memberId              String
  member                Member          @relation(fields: [memberId], references: [id])
  providerId            String
  provider              Provider        @relation(fields: [providerId], references: [id])
  providerBranchId      String?
  providerBranch        ProviderBranch? @relation(fields: [providerBranchId], references: [id])
  caseType              CaseType
  status                CaseStatus      @default(OPEN)
  admissionDate         DateTime?
  expectedDischargeDate DateTime?
  dischargeDate         DateTime?
  primaryDiagnoses      Json? // same shape as Claim.diagnoses
  attendingDoctor       String?
  benefitCategory       BenefitCategory
  estimatedCost         Decimal?        @db.Decimal(14, 2)
  accruedAmount         Decimal         @default(0) @db.Decimal(14, 2) // sum of non-voided entries
  currency              String          @default("UGX")
  openedById            String
  openedBy              User            @relation("CaseOpenedBy", fields: [openedById], references: [id])
  closedById            String?
  closedBy              User?           @relation("CaseClosedBy", fields: [closedById], references: [id])
  closedAt              DateTime?

  claims         Claim[]
  serviceEntries CaseServiceEntry[]
  preauths       PreAuthorization[]
  lous           LetterOfUndertaking[]
  documents      Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, caseNumber])
  @@index([tenantId, status])
  @@index([tenantId, providerId, status])
  @@index([memberId])
}

model CaseServiceEntry {
  id          String            @id @default(cuid())
  caseId      String
  case        ClinicalCase      @relation(fields: [caseId], references: [id])
  entryDate   DateTime
  category    ClaimLineCategory
  serviceCode String?
  description String
  quantity    Int               @default(1)
  unitAmount  Decimal           @db.Decimal(14, 2)
  totalAmount Decimal           @db.Decimal(14, 2)
  source      String            @default("MANUAL") // MANUAL | HMS_BATCH
  enteredById String?
  hmsBatchRef String?
  voided      Boolean           @default(false) // never delete — void instead
  voidReason  String?
  // IPL-001 interim settlement: when set, this entry is frozen into an interim
  // (or final) claim slice and is immutable — it can never be voided or
  // re-billed on a later slice. `null` = still unbilled, eligible for the next
  // Friday cut-off. This is the identity-based double-billing guard (plan SET-02:
  // "prior lines excluded by identity, not description guess").
  billedInClaimId String?
  billedInClaim   Claim?            @relation("SliceEntries", fields: [billedInClaimId], references: [id])
  createdAt   DateTime          @default(now())

  @@index([caseId, entryDate])
  @@index([hmsBatchRef])
  @@index([billedInClaimId])
}

// Letter of Undertaking (WP-D1, decision D6): a payer undertaking issued to a
// facility for an admission — distinct from a pre-auth GOP. Carries an amount
// ceiling and validity window; optionally attached to a case.
enum LouStatus {
  DRAFT
  ISSUED
  EXHAUSTED
  UTILISED
  CANCELLED
}

model LetterOfUndertaking {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  louNumber     String // e.g. LOU-2026-00001
  memberId      String
  member        Member        @relation(fields: [memberId], references: [id])
  providerId    String
  provider      Provider      @relation(fields: [providerId], references: [id])
  caseId        String?
  case          ClinicalCase? @relation(fields: [caseId], references: [id])
  amountCeiling Decimal       @db.Decimal(14, 2)
  currency      String        @default("UGX")
  status        LouStatus     @default(DRAFT)
  issuedById    String
  issuedBy      User          @relation("LouIssuedBy", fields: [issuedById], references: [id])
  issuedAt      DateTime?
  validFrom     DateTime?
  validUntil    DateTime?
  notes         String?
  documentId    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([tenantId, louNumber])
  @@index([tenantId, status])
  @@index([memberId])
  @@index([caseId])
}

// ─── BENEFIT HOLDS (Process 8) ────────────────────────────

enum HoldStatus {
  ACTIVE
  RELEASED
  CONVERTED
  EXPIRED
}

model BenefitHold {
  id                 String     @id @default(cuid())
  tenantId           String
  memberId           String
  preAuthId          String     @unique
  benefitCategory    String
  heldAmount         Decimal    @db.Decimal(14, 2)
  expiresAt          DateTime
  status             HoldStatus @default(ACTIVE)
  releasedAt         DateTime?
  convertedToClaimId String?
  createdAt          DateTime   @default(now())

  preAuth PreAuthorization @relation(fields: [preAuthId], references: [id])

  @@index([tenantId, memberId, status])
  @@index([tenantId, status, expiresAt])
}

// ─── PROVIDERS / FACILITIES ─────────────────────────────
enum ProviderType {
  HOSPITAL
  CLINIC
  PHARMACY
  LABORATORY
  DENTAL
  OPTICAL
  REHABILITATION
}

enum ProviderTier {
  OWN // Medvex own facilities
  PARTNER // Contracted partner facilities
  PANEL // Wider panel
}

model Provider {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  name          String
  type          ProviderType
  tier          ProviderTier @default(PARTNER)
  address       String?
  county        String?
  phone         String?
  email         String?
  contactPerson String?

  // ── Legal identity & licensing (digital-contract spec §5.2, O1) ──
  // Trading name lives in `name`; these capture the legal/registered entity so
  // contract matching can resolve the naming variance seen across the corpus.
  legalName          String? // "AFRIHOSPITAL HOLDINGS LIMITED" vs trading "Life Care Hospitals"
  registrationNumber String? // company registration number
  licenceNumber      String? // facility operating licence
  licenceExpiry      DateTime?
  taxPin             String? // KRA PIN (Britam schedule)
  facilityLevel      String? // SHA "LEVEL 4" etc.
  bankDetailsRef     String? // link into settlement data (bank details stay in settlement module)

  // NEW: Geospatial and operational data
  geoLatitude    Decimal? @db.Decimal(9, 6)
  geoLongitude   Decimal? @db.Decimal(9, 6)
  isOpen24Hours  Boolean  @default(false)
  operatingHours Json? // e.g., { "Mon": "08:00-17:00" }

  servicesOffered    String[] // ["Inpatient", "Outpatient", "Maternity", "Surgery", "Pharmacy", "ICU"]
  contractStatus     String    @default("ACTIVE") // ACTIVE, PENDING, EXPIRED
  contractStartDate  DateTime?
  contractEndDate    DateTime?
  paymentTermDays    Int       @default(30) // e.g. Net 30, Net 14
  creditLimit        Decimal? // Maximum outstanding payable (KES)
  contractNotes      String? // Free-text contract summary / special terms
  smartProviderId    String? // SMART provider code
  slade360ProviderId String? // Slade360 provider code
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tariffs            ProviderTariff[]
  diagnosisTariffs   ProviderDiagnosisTariff[]
  contracts          ProviderContract[]
  claims             Claim[]
  preauths           PreAuthorization[]
  settlementBatches  ProviderSettlementBatch[]
  checkInChallenges  CheckInChallenge[]
  checkInEvents      CheckInEvent[]
  visitVerifications VisitVerification[]
  eligibilityRules   PackageProviderEligibility[]
  practitioners      ProviderPractitioner[]
  branches           ProviderBranch[]
  aliases            ProviderAlias[]
  offlineWorkAuths   OfflineWorkAuthorization[]
  offlineDataPacks   OfflineDataPack[]
  clinicalCases      ClinicalCase[]
  lettersOfUndertaking LetterOfUndertaking[]
  portalUsers        User[]                    @relation("ProviderPortalUser")
  apiKeys            ProviderApiKey[]

  @@index([tenantId])
  @@index([tenantId, tier])
}

// Provider-scoped API credential for HMS / facility-system integration (B2B).
// Facilities with a hospital management system post claims/eligibility to
// /api/v1/* using their own key; the key resolves to exactly one Provider so
// every submission is attributed to that facility. Only a bcrypt hash of the
// key is stored; the plaintext is shown once at generation.
model ProviderApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id])
  label       String // human label, e.g. "Slade360 production"
  keyPrefix   String // first 12 chars of the plaintext key, for display/lookup
  keyHash     String // bcrypt hash of the full key
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  @@index([tenantId])
  @@index([providerId])
  @@index([keyPrefix])
}

// A physical branch/facility of a provider network (spec §5.2). Branch-level
// rates (O10) and branch-scoped contracts (Britam, SHA per-branch) are
// unmatchable without this.
model ProviderBranch {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  providerId    String
  provider      Provider @relation(fields: [providerId], references: [id])
  name          String // Bungoma, Migori, Eldoret, Meru, Kikuyu, Mlolongo
  code          String? // short branch code
  address       String?
  county        String?
  geoLatitude   Decimal? @db.Decimal(9, 6)
  geoLongitude  Decimal? @db.Decimal(9, 6)
  licenceNumber String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  claims           Claim[]
  contractBranches ContractBranch[]
  tariffLines      ProviderTariff[]
  offlineWorkAuths OfflineWorkAuthorization[]
  clinicalCases    ClinicalCase[]

  @@index([tenantId, providerId])
  @@index([providerId, isActive])
}

// Name variants for a provider (spec §5.2, O1) — resolves the legal/trading
// name spread during extraction and EDI intake.
model ProviderAlias {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  aliasName  String
  source     String? // where the alias was observed (e.g. "Britam 2024 contract")
  createdAt  DateTime @default(now())

  @@index([tenantId, providerId])
  @@index([tenantId, aliasName])
}

enum TariffType {
  NEGOTIATED
  PUBLISHED
  GAZETTED
}

// How a tariff line's payable is computed (digital-contract spec §5.6/§5.7).
// Phase 2 prices FIXED / DISCOUNT_OFF_BILLED / MARKUP_OVER_COST / PER_DIEM;
// the remaining kinds are valid values that route to manual review until their
// pricing lands in Phase 3.
enum TariffRateType {
  FIXED // pay contracted amount (LOWER_OF billed vs rate by default)
  DISCOUNT_OFF_BILLED // billed × (1 − discountPct)
  MARKUP_OVER_COST // cost basis × (1 + markupPct)
  PER_DIEM // rate × length-of-stay days
  EXTERNAL_TARIFF_REF // Phase 3 — rate from an external tariff table
  NET_OF_EXTERNAL // Phase 3 — payable = rate; gross = rate + external rebate
  CAPITATION // Phase 3/5 — per-member-per-period pool
  AVERAGE_COST_POOL // Phase 3/5 — portfolio reconciliation, not line-priced
}

// Unit the contracted rate is expressed in (spec §5.6) — used for UoM-mismatch
// detection (E20) and per-diem/quantity maths.
enum UnitOfMeasure {
  PER_ITEM
  PER_HOUR // Oxygen Therapy Per Hour
  PER_DAY // ward/ICU daily
  PER_VISIT
  PER_SESSION // dialysis, brachytherapy
  PER_EPISODE
  PER_ADMISSION
  PER_PROCEDURE
  PER_CONSULTATION
  PER_KM_BAND // ambulance distance bands
}

// Window a frequency limit is counted over (spec §5.6).
enum FrequencyPeriod {
  DAY
  VISIT
  ADMISSION
  YEAR
}

// Coding system a tariff line is keyed by (spec §5.6).
enum CodingSystem {
  CPT
  ICD10
  LOCAL
  SHA_PACKAGE
}

// OP/IP/OT service class (Masters convention; spec §5.5).
enum PatientClass {
  OP // outpatient
  IP // inpatient
  OT // theatre / operating
}

model ProviderTariff {
  id                  String            @id @default(cuid())
  providerId          String
  provider            Provider          @relation(fields: [providerId], references: [id])
  contractId          String? // null = standalone/legacy rate not tied to an agreement
  contract            ProviderContract? @relation(fields: [contractId], references: [id])
  // Version pinning (digital-contract spec §4.4/§5.6): the version that priced
  // this line. null = pre-versioning / standalone rate.
  versionId           String?
  version             ContractVersion?  @relation(fields: [versionId], references: [id])
  // Branch-scoped rate (spec §5.6, O10): null = all branches in contract scope.
  branchId            String?
  branch              ProviderBranch?   @relation(fields: [branchId], references: [id])
  // Per-client tariff (G5.4): null = shared master rate for the network; set =
  // this client's negotiated rate for the provider service (wins at resolution).
  clientId            String?
  client              Client?           @relation(fields: [clientId], references: [id])
  cptCode             String?
  serviceName         String
  agreedRate          Decimal // overrides standard CPT charge for this provider
  currency            String            @default("UGX") // G3.5
  tariffType          TariffType        @default(NEGOTIATED)
  requiresPreauth     Boolean           @default(false) // contract requires PA before this service is payable
  maxQuantityPerVisit Int? // contractual cap on units per encounter

  // ── Phase 2: mapping + pricing extensions (spec §5.6) ──
  serviceCategoryId    String? // canonical taxonomy link (§5.5)
  serviceCategory      ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  providerServiceCode  String? // provider master / HMS code (e.g. SER015) — join key to provider bills (O21)
  providerDescription  String? // raw contract text preserved
  standardDescription  String? // normalised service name
  codingSystem         CodingSystem?
  rateType             TariffRateType   @default(FIXED)
  discountPct          Decimal?         @db.Decimal(5, 2) // for DISCOUNT_OFF_BILLED
  markupPct            Decimal?         @db.Decimal(5, 2) // for MARKUP_OVER_COST
  maxPayableAmount     Decimal?         @db.Decimal(14, 2) // ceiling independent of rate
  minPayableAmount     Decimal?         @db.Decimal(14, 2) // floor independent of rate
  unitOfMeasure        UnitOfMeasure    @default(PER_ITEM)
  quantityLimit        Int? // hard cap on units (beyond maxQuantityPerVisit semantics)
  frequencyLimit       Int? // e.g. "1 Visit Per Day/Per Consultant"
  frequencyPeriod      FrequencyPeriod?
  genderRestriction    String? // "M" | "F" — maternity/paeds tariffs
  ageMin               Int?
  ageMax               Int?
  diagnosisRestriction Json? // ICD list/pattern — SHA MRI/CT indication limits
  requiresReferral     Boolean          @default(false) // SHA imaging self-referral ban
  rateMissing          Boolean          @default(false) // O2/O13 — line exists, price unreadable; blocks activation (§13-V6)
  // External-scheme offset (spec §5.6/§5.7 P3/P12) — for NET_OF_EXTERNAL /
  // EXTERNAL_TARIFF_REF rate types. externalScheme keys the ExternalTariffTable
  // lookup; externalRebateAmount is the known offset when printed on the contract.
  externalScheme       String? // NHIF | SHA | ...
  externalRebateAmount Decimal?         @db.Decimal(14, 2)
  sourceRef            Json? // { documentId, page, rawText, confidence }
  notes                String?

  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true) // Never delete — deactivate instead
  createdAt     DateTime  @default(now())

  mappingMemories ServiceMappingMemory[]

  @@index([providerId])
  @@index([providerId, cptCode])
  @@index([providerId, isActive])
  @@index([providerId, providerServiceCode])
  @@index([contractId])
  @@index([versionId])
  @@index([branchId])
  @@index([clientId])
  @@index([serviceCategoryId])
  @@index([contractId, rateMissing])
}

// Contract fee-schedule tier (WP-E1 / TPA_FEEDBACK_WORKPLAN.md D7): groups the
// taxonomy into the bands a fee-for-service contract is negotiated in.
enum ServiceTier {
  HEADLINE // most-common services: consultations, ward/ICU per day, ER fee
  LABORATORY
  IMAGING
  PHARMACY // drugs + consumables
  THEATRE // theatre time bands, OT equipment
  PROFESSIONAL_FEES // surgeon / anaesthetist / doctor fees
  OTHER // dental, optical, physio, ambulance, dialysis, packages…
}

// ─── SERVICE CATALOGUE / TAXONOMY (spec §5.5) ────────────────────────────
// Canonical, tenant-level service taxonomy that contract tariff lines and claim
// lines map onto. Seeded from the §2.2 category list + provider Masters.
model ServiceCategory {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  code         String // canonical code, e.g. RADIOLOGY, CT_SCAN
  name         String
  parentId     String? // hierarchy: RADIOLOGY > CT_SCAN
  parent       ServiceCategory?  @relation("ServiceCategoryTree", fields: [parentId], references: [id])
  children     ServiceCategory[] @relation("ServiceCategoryTree")
  patientClass PatientClass?
  // Fee-schedule tier (WP-E1): set on top-level categories; children inherit
  // at read time. Null = unmapped (renders in the OTHER bucket with a chip).
  tier         ServiceTier?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  aliases     ServiceCategoryAlias[]
  tariffLines ProviderTariff[]
  claimLines  ClaimLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, tier])
  @@index([parentId])
}

// Raw corpus labels → canonical category (spec §5.5, O11: "Mo Minor Procedure").
model ServiceCategoryAlias {
  id                String          @id @default(cuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  serviceCategoryId String
  serviceCategory   ServiceCategory @relation(fields: [serviceCategoryId], references: [id])
  rawLabel          String
  source            String?
  createdAt         DateTime        @default(now())

  @@index([tenantId, rawLabel])
  @@index([serviceCategoryId])
}

// Learned, maker-confirmed service→tariff mappings reused by the engine's fuzzy
// description matcher (spec §6.3). Written by the MAP_SERVICE_TO_TARIFF override.
model ServiceMappingMemory {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  providerId     String? // null = applies across the provider's tariffs
  contractId     String? // null = across contracts
  normalizedText String // lower-cased, trimmed billed description
  tariffId       String
  tariff         ProviderTariff @relation(fields: [tariffId], references: [id])
  confirmedById  String?
  createdAt      DateTime       @default(now())

  @@index([tenantId, normalizedText])
  @@index([tariffId])
}

// Diagnosis-based bundled rates — e.g. malaria admission = KES 8,000/day flat
model ProviderDiagnosisTariff {
  id             String            @id @default(cuid())
  providerId     String
  provider       Provider          @relation(fields: [providerId], references: [id])
  contractId     String? // null = standalone/legacy rate not tied to an agreement
  contract       ProviderContract? @relation(fields: [contractId], references: [id])
  icdCode        String // ICD-10 code this rate applies to
  diagnosisLabel String // Human-readable label (copied at time of creation)
  bundledRate    Decimal? // Fixed package rate for the whole episode (KES)
  perDayRate     Decimal? // Per diem rate (KES/day) — for inpatient
  tariffType     TariffType        @default(NEGOTIATED)
  notes          String? // Any special conditions or inclusions
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  isActive       Boolean           @default(true) // Never delete — deactivate instead
  createdAt      DateTime          @default(now())

  @@index([providerId])
  @@index([providerId, icdCode])
  @@index([contractId])
}

// ─── PROVIDER CONTRACTS ─────────────────────────────────
// A signed commercial agreement with a provider. Owns the rate schedule,
// exclusions, and billing rules that adjudication enforces.

enum ProviderContractStatus {
  DRAFT // being negotiated — rates not yet applied; invisible to claims engine
  UNDER_REVIEW // submitted for approval — reviewer comments/approves/rejects (spec §4.2)
  PENDING_CLARIFICATION // editor answering reviewer queries
  APPROVED // approved, not yet activated (auto-activates at startDate)
  ACTIVE // in force — adjudication uses this contract's schedule
  SUSPENDED // temporarily not honoured (e.g. compliance issue)
  EXPIRED // past end date
  TERMINATED // ended early
  SUPERSEDED // replaced by a successor contract; read-only historical
  ARCHIVED // read-only; excluded from default lists
  VOIDED // PR-010 D2: abandoned in DRAFT with a reason; excluded from default lists/dropdowns, never deletable
}

// Digital-contract taxonomy (spec §3.3) — the shape of the agreement.
enum ContractType {
  MASTER_SERVICE_AGREEMENT // full legal agreement, usually rate-silent or schedule-carrying
  RATE_SCHEDULE // pricelist letter attached to an MSA
  PACKAGE_AGREEMENT // surgical/maternity/dental package price sets
  CASE_RATE_AGREEMENT // fixed-fee-per-visit / FCM / capitation-style
  RECONCILIATION_AGREEMENT // average-cost / discount addenda settled by reconciliation
  ADDENDUM // amends a parent contract
  GOVERNMENT_SCHEME_CONTRACT // statutory scheme contract (SHA)
}

// Whether a contract applies to every branch of the provider or an explicit list
// (spec §5.1 O10 — Britam signing-entity trap).
enum ContractBranchScope {
  ALL_BRANCHES
  LISTED // requires ≥1 ContractBranch row
}

// Execution/signature evidence (spec §5.1 O22). UNSIGNED blocks activation without override.
enum ContractExecutionStatus {
  FULLY_EXECUTED
  PROVIDER_ONLY
  UNSIGNED
}

// Payment-term day counting (spec §5.1 — Jubilee "10 working days").
enum PaymentTermType {
  CALENDAR
  BUSINESS
}

// What date the submission window is measured from (spec §5.1 — SHA 7 days).
enum SubmissionWindowBasis {
  SERVICE_DATE
  DISCHARGE_DATE
  INVOICE_DATE
  MONTHLY_BATCH
}

// Whether the provider may bill the member for the shortfall (spec §5.1 O19, SHA GCC 12.15/12.16).
enum BalanceBillingPolicy {
  PROHIBITED
  ALLOWED_NONCOVERED_WITH_CONSENT
  ALLOWED
}

// Reconciliation settlement cadence (spec §5.1 — Old Mutual quarterly, Jubilee monthly).
enum ReconciliationCadence {
  NONE
  WEEKLY
  MONTHLY
  QUARTERLY
  BIANNUAL
}

// Tri-state tax inclusivity (spec §5.1 — SHA inclusive; commercial letters silent).
enum TaxInclusivity {
  INCLUSIVE
  EXCLUSIVE
  UNKNOWN
}

// Contract version snapshot lifecycle (spec §4.4).
enum ContractVersionStatus {
  DRAFT // being edited; not yet approved
  APPROVED // approved, awaiting effective date
  ACTIVE // the version currently pricing claims within its window
  SUPERSEDED // replaced by a later version
}

// How services NOT on the tariff schedule are paid. This is the single most
// important billing rule in a provider agreement — without it every uncoded
// invoice line is payable at whatever the provider billed.
enum UnlistedServiceRule {
  PAY_AS_BILLED // honour billed charges for unlisted services
  DISCOUNT_OFF_BILLED // pay billed × (1 − unlistedDiscountPct)
  REFER_FOR_REVIEW // no automatic ceiling — flag for manual adjudication
  REJECT // unlisted services are not payable at all
}

model ProviderContract {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])

  contractNumber String // PC-2026-001 — generated per tenant
  title          String // e.g. "2026 Master Services Agreement"
  contractType   ContractType           @default(RATE_SCHEDULE) // spec §3.3
  status         ProviderContractStatus @default(DRAFT)

  // ── Provider/payer scope (spec §5.1) ──
  branchScope         ContractBranchScope @default(ALL_BRANCHES) // LISTED requires ≥1 ContractBranch (O10)
  externalContractRef String? // e.g. SHA "CN-73009"

  // Parent/child linkage — ADDENDUM / RATE_SCHEDULE under an MSA (spec §5.1, O6).
  parentContractId String?
  parentContract   ProviderContract?  @relation("ContractFamily", fields: [parentContractId], references: [id])
  children         ProviderContract[] @relation("ContractFamily")
  parentDigitised  Boolean            @default(true) // false warns the controlling parent MSA is not in the system

  startDate     DateTime
  endDate       DateTime
  reviewDueDate DateTime? // spec O4 "subject to review" — distinct from endDate; does NOT auto-expire
  signedDate    DateTime?
  autoRenew     Boolean   @default(false)

  // ── Execution / signature evidence (spec §5.1 O22) ──
  executionStatus ContractExecutionStatus @default(UNSIGNED) // UNSIGNED blocks activation without override
  signatories     Json? // [{ party, name, designation, date }]

  currency String  @default("KES") // ISO 4217; corpus = KES. Default seeded from Client.currency at creation
  country  String?
  region   String?

  // Commercial terms
  paymentTermDays    Int             @default(30)
  paymentTermType    PaymentTermType @default(CALENDAR) // Jubilee "10 working days" → BUSINESS
  creditLimit        Decimal? // max outstanding payable (KES)
  invoiceDiscountPct Decimal? // negotiated % discount applied across the invoice

  // Early-settlement discount (spec P7) — consumed by settlement, not adjudication.
  earlySettlementDiscountPct Decimal? @db.Decimal(5, 2) // Old Mutual 2%
  earlySettlementWindowDays  Int? // within 30 days

  // Submission window (spec §5.1 — SHA 7 days) — consequence = reason SUB-001.
  submissionWindowDays  Int?
  submissionWindowBasis SubmissionWindowBasis?

  // Operational policy terms
  balanceBillingPolicy  BalanceBillingPolicy? // SHA GCC 12.15/12.16 (O19)
  taxInclusive          TaxInclusivity        @default(UNKNOWN) // SHA GCC 13 inclusive; commercial letters silent
  reconciliationCadence ReconciliationCadence @default(NONE) // Old Mutual quarterly; Jubilee monthly

  // Billing rules
  unlistedServiceRule UnlistedServiceRule @default(REFER_FOR_REVIEW)
  unlistedDiscountPct Decimal? // required when unlistedServiceRule = DISCOUNT_OFF_BILLED

  documentUrl String? // scanned signed agreement (legacy single-doc link; multi-doc via ContractSourceDocument)
  notes       String?

  // Renewal chain: old contract points at the contract that replaced it
  supersededById String?           @unique
  supersededBy   ProviderContract? @relation("ContractRenewal", fields: [supersededById], references: [id])
  predecessor    ProviderContract? @relation("ContractRenewal")

  // ── Versioning & ownership (spec §4.4, §5.1) — maker ≠ checker enforced in service ──
  currentVersionId String?          @unique
  currentVersion   ContractVersion? @relation("ContractCurrentVersion", fields: [currentVersionId], references: [id])
  contractOwnerId  String?
  createdById      String?
  submittedById    String?
  submittedAt      DateTime?
  approvedById     String?
  approvedAt       DateTime?
  activatedById    String?
  activatedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tariffLines        ProviderTariff[]
  diagnosisTariffs   ProviderDiagnosisTariff[]
  exclusions         ProviderContractExclusion[]
  versions           ContractVersion[]           @relation("ContractVersions")
  applicability      ContractApplicability[]
  contractBranches   ContractBranch[]
  sourceDocuments    ContractSourceDocument[]
  claims             Claim[]
  pricingRules       PricingRule[]
  contractPackages   ContractPackage[]
  preauthRules       PreauthRule[]
  documentationRules DocumentationRule[]

  @@unique([tenantId, contractNumber])
  @@index([providerId, status])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, providerId, status])
  @@index([parentContractId])
  @@index([endDate])
  @@index([reviewDueDate])
}

// Immutable version snapshot of a contract's operative content (spec §4.4).
// The version effective on the SERVICE DATE prices a claim. New versions are
// created in DRAFT and leave version n live until approved + effective.
model ContractVersion {
  id            String                @id @default(cuid())
  tenantId      String
  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  contractId    String
  contract      ProviderContract      @relation("ContractVersions", fields: [contractId], references: [id], onDelete: Cascade)
  versionNumber Int
  status        ContractVersionStatus @default(DRAFT)
  effectiveFrom DateTime
  effectiveTo   DateTime? // set when superseded by a later version

  // Snapshot of contract-level operative fields at version-cut time. Child rows
  // (tariffs, rules) are version-pinned via their own versionId FK.
  snapshot         Json? // metadata + terms snapshot for diffing
  validationReport Json? // §13 validation result persisted with the version, shown to the approver
  changeSummary    String? // human note describing what changed vs the prior version

  createdById  String?
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  currentOf   ProviderContract? @relation("ContractCurrentVersion")
  tariffLines ProviderTariff[]

  @@unique([contractId, versionNumber])
  @@index([tenantId])
  @@index([contractId, status])
  @@index([contractId, effectiveFrom])
}

// Which populations a contract governs (spec §5.4). Evaluated as: specific
// INCLUDE rows win over payer-wide default; EXCLUDE rows always win (§7).
model ContractApplicability {
  contractId String
  contract   ProviderContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  versionId  String? // null = applies across versions
  id         String           @id @default(cuid())

  clientId         String // payer
  client           Client           @relation(fields: [clientId], references: [id])
  groupId          String? // scheme/employer group; null = all payer groups
  packageId        String? // plan; null = all plans
  packageVersionId String?
  benefitCategory  BenefitCategory? // restrict to e.g. DENTAL (KCB/Madison dental letters)
  networkTier      ProviderTier? // reuse existing tier as "network"
  memberCategory   String? // e.g. SHA "registered, fully paid-up and officially declared"

  inclusionType EligibilityRule @default(INCLUDE)

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@index([contractId])
  @@index([clientId])
  @@index([contractId, clientId])
}

// Branch coverage for contracts with branchScope = LISTED (spec §5.1, O10).
model ContractBranch {
  id         String           @id @default(cuid())
  contractId String
  contract   ProviderContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  branchId   String
  branch     ProviderBranch   @relation(fields: [branchId], references: [id])
  createdAt  DateTime         @default(now())

  @@unique([contractId, branchId])
  @@index([contractId])
  @@index([branchId])
}

// Source-document join (spec §3.2) — a contract may have several sources
// (main agreement + addenda + rate letters). The document is evidence; the
// structured contract is the executable.
model ContractSourceDocument {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  contractId   String
  contract     ProviderContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  documentId   String? // FK into existing Document model when stored there
  fileUrl      String? // direct URL when not yet a Document row
  fileName     String?
  sourceRole   String? // MAIN_AGREEMENT | RATE_LETTER | ADDENDUM | OTHER
  status       String           @default("UPLOADED") // UPLOADED | PARSED | REVIEWED (extraction pipeline §12)
  uploadedById String?
  createdAt    DateTime         @default(now())

  @@index([tenantId])
  @@index([contractId])
}

// Multi-level exclusion (digital-contract spec §5.9). Generalises the original
// CPT/name exclusion with a level + diagnosis/plan/date/branch scoping so the
// engine can evaluate contract exclusions at stage 5.
enum ExclusionLevel {
  CONTRACT
  CATEGORY
  TARIFF_LINE
  DIAGNOSIS
  PLAN
  MEMBER_CATEGORY
  DATE_RANGE
}

// Services that are contractually NOT payable at this provider
// (e.g. cosmetic procedures, services the facility is not accredited for).
model ProviderContractExclusion {
  id          String           @id @default(cuid())
  contractId  String
  contract    ProviderContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  versionId   String?
  cptCode     String? // match by CPT when coded
  serviceName String // human-readable service description (used for display + uncoded match)
  reason      String? // why it is excluded

  // ── Phase 3 generalisation (§5.9) ──
  level             ExclusionLevel @default(TARIFF_LINE)
  serviceCategoryId String? // CATEGORY level
  icdCodes          String[]       @default([]) // DIAGNOSIS level (SHA MRI/CT indication limits)
  packageId         String? // PLAN level (benefits Package)
  memberCategory    String? // MEMBER_CATEGORY level
  dateFrom          DateTime? // DATE_RANGE level
  dateTo            DateTime?
  appliesToBranchId String?
  sourceRef         Json?

  createdAt DateTime @default(now())

  @@index([contractId])
  @@index([contractId, cptCode])
  @@index([contractId, level])
}

// ─── CONTRACT EXTRACTION (spec §12, Phase 4) ─────────────────────────────────
// A run of the markdown/PDF extraction pipeline over a source document. The
// extractor is assistive and NEVER activates anything: candidates carry
// provenance + confidence and require human confirmation. Zero-hallucination —
// no amount enters a field without a source-cell provenance record.
enum ExtractionStatus {
  UPLOADED
  PARSED // candidates produced, awaiting review
  REVIEWED // human confirmed/answered ambiguities
  COMMITTED // written to a DRAFT contract
  FAILED
}

model ContractExtraction {
  id               String           @id @default(cuid())
  tenantId         String
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  contractId       String? // set when committed to a draft contract
  sourceDocumentId String? // ContractSourceDocument
  fileName         String?
  status           ExtractionStatus @default(UPLOADED)
  extractorVersion String           @default("rule-based-v1")

  // Extracted entities: { effectiveDateCandidates[], reviewBased, externalRefs[], providerNames[], currencyStated, taxStated }
  entities         Json?
  // Array of { description, category, canonicalCategory, amount|null, rateMissing, sourceRef{page,rawText}, confidence }
  tariffCandidates Json  @default("[]")
  // Array of { type, message, candidates[] } — each a mandatory review question (§12.7)
  ambiguities      Json  @default("[]")
  reviewAnswers    Json? // human answers keyed by ambiguity/field
  stats            Json? // { rowsDetected, rowsWithRate, rowsMissingRate }

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([contractId])
}

// ─── AVERAGE-COST RECONCILIATION (spec §15.12, Phase 5) ──────────────────────
// A computed recovery/settlement proposal for an average-cost pool over a
// period (Old Mutual clauses 1.1-1.3). Reconciliation adjustments are NEVER
// auto-posted: they are finance maker-checker actions.
enum ReconciliationStatus {
  COMPUTED // proposal generated
  APPROVED // finance-approved for settlement
  REJECTED
  SETTLED // adjustment posted
}

model ContractReconciliation {
  id            String               @id @default(cuid())
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  contractId    String?
  poolId        String // AVERAGE_COST_POOL tag (Claim.avgCostPoolId)
  periodStart   DateTime
  periodEnd     DateTime
  agreedAverage Decimal              @db.Decimal(14, 2) // agreed gross average cost (e.g. 4,000)
  claimCount    Int
  agreedTotal   Decimal              @db.Decimal(14, 2) // agreedAverage × claimCount
  billedTotal   Decimal              @db.Decimal(14, 2)
  recovery      Decimal              @db.Decimal(14, 2) // max(0, billedTotal − agreedTotal)
  status        ReconciliationStatus @default(COMPUTED)
  computedById  String?
  approvedById  String? // must differ from computedById (maker-checker)
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([tenantId])
  @@index([tenantId, poolId])
  @@index([contractId])
}

// ─── DIGITAL CONTRACT RULE ENGINE — PHASE 3 MODELS ───────────────────────────

// Scope a pricing/pre-auth/documentation rule attaches at (spec §5.7).
enum ContractRuleScope {
  CONTRACT
  CATEGORY
  LINE
  PACKAGE
}

// Typed pricing rules (spec §5.7) — superset of the corpus pricing models P1–P12.
enum PricingRuleKind {
  FIXED
  DISCOUNT_OFF_BILLED
  MARKUP_OVER_COST
  MAX_CAP
  MIN_FLOOR
  PER_DIEM
  PER_VISIT_CASE_RATE // Madison FCM / Jubilee capitation — fixed per valid visit with carve-outs
  PER_ADMISSION
  PER_PROCEDURE
  PER_CONSULTATION
  PER_ITEM
  PER_SESSION
  PACKAGE
  CAPITATION
  NET_OF_EXTERNAL
  EXTERNAL_TARIFF_REF
  AVERAGE_COST_POOL
  LOWER_OF
  HIGHER_OF
}

// A typed pricing rule attached at contract/category/line scope (spec §5.7).
// `params` is a kind-specific JSON payload validated in the service layer.
model PricingRule {
  id                String            @id @default(cuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  contractId        String
  contract          ProviderContract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  versionId         String?
  scope             ContractRuleScope @default(CONTRACT)
  serviceCategoryId String?
  tariffLineId      String?
  ruleKind          PricingRuleKind
  params            Json              @default("{}") // e.g. { rate, pct, payBasis, carveOutCodes, poolId, scheme }
  priority          Int               @default(100)
  effectiveFrom     DateTime          @default(now())
  effectiveTo       DateTime?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())

  @@index([contractId, isActive])
  @@index([tenantId])
}

// How a package is triggered off a claim (spec §5.8).
enum PackageTriggerType {
  PROCEDURE_CODE
  DIAGNOSIS_CODE
  SERVICE_DESCRIPTION
}

// What happens when a complication falls outside the package (spec §5.8).
enum ComplicationRule {
  EXCLUDED_BILL_SEPARATELY // CIC: complications → ICU excluded = revert to FFS/per-diem
  INCLUDED
  ESCALATE
}

// Episode-priced procedure set (spec §5.8, family B). Distinct from the benefits
// `Package` (plan design) — this is a surgical/case package price.
model ContractPackage {
  id                        String             @id @default(cuid())
  tenantId                  String
  tenant                    Tenant             @relation(fields: [tenantId], references: [id])
  contractId                String
  contract                  ProviderContract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  versionId                 String?
  name                      String // "Caesarean Section Package"
  code                      String?
  packagePrice              Decimal            @db.Decimal(14, 2)
  currency                  String             @default("KES")
  netOfExternalScheme       String? // P3 "Net of NHIF"
  externalRebateAmount      Decimal?           @db.Decimal(14, 2)
  triggerType               PackageTriggerType @default(PROCEDURE_CODE)
  triggerCodes              String[]           @default([]) // CPT/ICD/local codes or normalised names
  losAssumptionDays         Int?
  losCapDays                Int?
  complicationRule          ComplicationRule   @default(EXCLUDED_BILL_SEPARATELY)
  unbundlingAllowed         Boolean            @default(false)
  packageOverridesLineItems Boolean            @default(true)
  genderRestriction         String?
  effectiveFrom             DateTime           @default(now())
  effectiveTo               DateTime?
  isActive                  Boolean            @default(true)
  createdAt                 DateTime           @default(now())

  components PackageComponent[]

  @@index([contractId, isActive])
  @@index([tenantId])
}

enum PackageComponentType {
  INCLUDED // priced inside the package (zero-priced separately)
  EXCLUDED // priced independently (complications, advanced imaging)
}

// A typed inclusion/exclusion of a package with an optional quantity cap
// (spec §5.8 — e.g. orthopaedic "Two X-rays" → qtyCap 2).
model PackageComponent {
  id          String               @id @default(cuid())
  packageId   String
  package     ContractPackage      @relation(fields: [packageId], references: [id], onDelete: Cascade)
  type        PackageComponentType
  description String
  code        String?
  qtyCap      Int?
  createdAt   DateTime             @default(now())

  @@index([packageId])
}

// Pre-authorisation trigger type (spec §5.10).
enum PreauthTriggerType {
  SERVICE_LIST
  AMOUNT_THRESHOLD
  ADMISSION
  LOS_BEYOND
  ALWAYS
}

enum PreauthConsequence {
  REJECT // AUTH-001
  ROUTE_MANUAL
  PAY_WITH_PENALTY
}

// Contract-sourced pre-authorisation rule (spec §5.10). Feeds the existing
// PreAuthorization module and the engine's stage-6 check.
model PreauthRule {
  id                       String             @id @default(cuid())
  tenantId                 String
  tenant                   Tenant             @relation(fields: [tenantId], references: [id])
  contractId               String
  contract                 ProviderContract   @relation(fields: [contractId], references: [id], onDelete: Cascade)
  versionId                String?
  scope                    ContractRuleScope  @default(CONTRACT)
  serviceCategoryId        String?
  tariffLineId             String?
  packageId                String?
  triggerType              PreauthTriggerType @default(ALWAYS)
  thresholdAmount          Decimal?           @db.Decimal(14, 2) // LOU for services > X
  serviceRefs              String[]           @default([]) // FCM carve-out lists
  admissionRequired        Boolean            @default(false)
  emergencyExempt          Boolean            @default(false) // SHA GCC 11.1 (O17)
  retrospectiveAllowed     Boolean            @default(false)
  retrospectiveWindowHours Int?
  approvalSlaHours         Int? // SHA 72h
  validityDays             Int?
  requiredDocumentTypes    String[]           @default([])
  consequenceIfMissing     PreauthConsequence @default(ROUTE_MANUAL)
  effectiveFrom            DateTime           @default(now())
  effectiveTo              DateTime?
  isActive                 Boolean            @default(true)
  createdAt                DateTime           @default(now())

  @@index([contractId, isActive])
  @@index([tenantId])
}

// Documents a claim must carry (spec §5.11).
enum ContractDocumentType {
  INVOICE
  ITEMISED_BILL
  CLAIM_FORM
  PRESCRIPTION
  LAB_REQUEST
  LAB_RESULT
  DOCTOR_NOTES
  DISCHARGE_SUMMARY
  CARE_PLAN
  MEDICAL_REPORT
  REFERRAL_LETTER
  PREAUTH_APPROVAL // LOU
  THEATRE_NOTES
  DELIVERY_NOTES
  IMAGING_REPORT
  RADIOLOGY_REPORT_STRUCTURED
  OTHER
}

enum DocConsequence {
  REJECT // DOC-001
  ROUTE // DOC-002 route
  PEND_PROVIDER // pend for provider
}

// Documentation requirement rule (spec §5.11).
model DocumentationRule {
  id                   String               @id @default(cuid())
  tenantId             String
  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  contractId           String
  contract             ProviderContract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  versionId            String?
  scope                ContractRuleScope    @default(CONTRACT)
  serviceCategoryId    String?
  tariffLineId         String?
  documentType         ContractDocumentType
  mandatory            Boolean              @default(true)
  appliesWhen          Json? // e.g. { onlyIP: true } or { amountOver: 10000 }
  consequenceIfMissing DocConsequence       @default(ROUTE)
  effectiveFrom        DateTime             @default(now())
  effectiveTo          DateTime?
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())

  @@index([contractId, isActive])
  @@index([tenantId])
}

// External scheme tariff table (spec §5.7 EXTERNAL_TARIFF_REF / NET_OF_EXTERNAL) —
// e.g. NHIF/SHA offsets keyed by (scheme, code, period). Unresolved → manual.
model ExternalTariffTable {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  scheme        String // NHIF | SHA | ...
  code          String
  description   String?
  rate          Decimal   @db.Decimal(14, 2)
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())

  @@unique([tenantId, scheme, code, effectiveFrom])
  @@index([tenantId, scheme, code])
}

// Per-(tenant, overrideType) governance config for claims-contract overrides
// (spec §9.3). Defaults ship conservative.
model OverrideControl {
  id                        String   @id @default(cuid())
  tenantId                  String
  tenant                    Tenant   @relation(fields: [tenantId], references: [id])
  overrideType              String // OverrideType enum name
  allowed                   Boolean  @default(true)
  requestorRoles            String[] @default([])
  approverRoles             String[] @default([])
  dualApprovalThreshold     Decimal? @db.Decimal(14, 2) // financial impact requiring 2 approvers
  maxFinancialImpact        Decimal? @db.Decimal(14, 2) // hard block above
  reasonCodeRequired        Boolean  @default(true)
  justificationMinLength    Int      @default(20)
  requiredDocumentTypes     String[] @default([])
  notifyProvider            Boolean  @default(false)
  notifyPayer               Boolean  @default(false)
  updatesAutomation         Boolean  @default(false) // only MAP_SERVICE_TO_TARIFF + CREATE_TEMPORARY_RATE may be reusable
  createsContractReviewTask Boolean  @default(false)
  isActive                  Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([tenantId, overrideType])
  @@index([tenantId])
}

// ─── PHASE B: PROVIDER & POLICY HARDENING ───────────────

enum EligibilityRule {
  INCLUDE
  EXCLUDE
}

model PackageProviderEligibility {
  id               String          @id @default(cuid())
  packageVersionId String
  packageVersion   PackageVersion  @relation(fields: [packageVersionId], references: [id])
  providerId       String?
  provider         Provider?       @relation(fields: [providerId], references: [id])
  providerTier     ProviderTier?
  inclusionType    EligibilityRule
  createdAt        DateTime        @default(now())

  @@index([packageVersionId])
  @@index([providerId])
}

model Practitioner {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  firstName     String
  lastName      String
  licenseType   String
  licenseNumber String
  phone         String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  credentials PractitionerCredential[]
  providers   ProviderPractitioner[]

  @@unique([tenantId, licenseNumber])
  @@index([tenantId])
}

enum PractitionerCredentialStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

model PractitionerCredential {
  id             String                       @id @default(cuid())
  practitionerId String
  practitioner   Practitioner                 @relation(fields: [practitionerId], references: [id])
  documentType   String
  documentUrl    String?
  issueDate      DateTime?
  expiryDate     DateTime
  status         PractitionerCredentialStatus @default(ACTIVE)
  notes          String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@index([practitionerId])
  @@index([expiryDate])
}

model ProviderPractitioner {
  providerId     String
  provider       Provider     @relation(fields: [providerId], references: [id])
  practitionerId String
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id])
  isPrimary      Boolean      @default(false)
  joinedAt       DateTime     @default(now())

  @@id([providerId, practitionerId])
  @@index([practitionerId])
}

enum ReinstatementStatus {
  PENDING
  APPROVED
  DECLINED
}

model MembershipReinstatementRequest {
  id                 String              @id @default(cuid())
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  memberId           String
  member             Member              @relation(fields: [memberId], references: [id])
  lapsedDate         DateTime
  requestDate        DateTime            @default(now())
  status             ReinstatementStatus @default(PENDING)
  catchUpAmount      Decimal             @db.Decimal(14, 2)
  periodsCovered     Int
  resetWaitingPeriod Boolean             @default(false)
  approvedById       String?
  approvedBy         User?               @relation(fields: [approvedById], references: [id])
  declineReason      String?
  decidedAt          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([tenantId, status])
  @@index([memberId])
}

// ─── BROKERS ─────────────────────────────────────────────
enum BrokerType {
  MASTER_BROKER
  SUB_AGENT
  TIED_AGENT
  INDIVIDUAL_PRODUCER
  BANCASSURANCE
}

enum IntermediaryCategory {
  REGULATED_BROKER
  REGULATED_AGENT
  INTRODUCER
  REFERRAL_PARTNER
  INTERNAL_SALES
  CORPORATE_AFFINITY
  BANCASSURANCE
  OTHER
}

enum CommissionBasis {
  COMMISSION
  REFERRAL_FEE
  ATTRIBUTION_ONLY
  NONE
}

enum KycDocumentType {
  IRA_LICENSE
  KRA_PIN_CERTIFICATE
  CR12
  PROFESSIONAL_INDEMNITY
  BANK_CONFIRMATION
  DIRECTORS_ID
  TAX_COMPLIANCE_CERTIFICATE
  ENGAGEMENT_LETTER
  REFERRAL_AGREEMENT
  OTHER
}

enum KycDocumentStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
}

enum CommissionScheduleType {
  FLAT_PERCENTAGE
  TIERED_VOLUME
  TIERED_LOSS_RATIO
  HYBRID_FLAT_PLUS_OVERRIDE
  PERFORMANCE_LINKED
}

enum ScheduleStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  SUPERSEDED
  REJECTED
}

enum TierMetric {
  GROSS_CONTRIBUTION_BAND
  MEMBER_COUNT_BAND
  LOSS_RATIO_BAND
  RENEWAL_RETENTION_BAND
}

enum CommissionState {
  PENDING_RECONCILIATION
  EARNED
  ACCRUED
  PAYABLE
  PAID
  CLAWED_BACK
  ON_HOLD
}

enum PayoutBatchStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  IN_TRANSIT
  COMPLETED
  PARTIAL_FAILURE
}

model Broker {
  id                      String               @id @default(cuid())
  tenantId                String
  tenant                  Tenant               @relation(fields: [tenantId], references: [id])
  name                    String // Company name
  brokerCode              String?              @unique
  legalName               String?
  tradingName             String?
  brokerType              BrokerType           @default(MASTER_BROKER)
  intermediaryCategory    IntermediaryCategory @default(REGULATED_BROKER)
  requiresIraRegistration Boolean              @default(true)
  canReceiveCommission    Boolean              @default(true)
  commissionBasis         CommissionBasis      @default(COMMISSION)
  referralFeeAmount       Decimal?             @db.Decimal(18, 2)
  sourceDescription       String?
  parentBrokerId          String?
  parent                  Broker?              @relation("BrokerHierarchy", fields: [parentBrokerId], references: [id])
  children                Broker[]             @relation("BrokerHierarchy")
  contactPerson           String
  phone                   String
  email                   String
  address                 String?
  licenseNumber           String? // IRA license
  iraExpiryDate           DateTime?
  kraPin                  String?
  vatRegistered           Boolean              @default(false)
  vatNumber               String?
  bankAccountReference    String?
  mpesaPaybillNumber      String?
  effectiveFrom           DateTime             @default(now())
  effectiveTo             DateTime?
  approvedById            String?
  approvedAt              DateTime?
  status                  String               @default("ACTIVE")
  dateOnboarded           DateTime             @default(now())

  // Commission structure
  firstYearCommissionPct Decimal  @default(0) // % of first-year contribution
  renewalCommissionPct   Decimal  @default(0) // % of renewal contribution
  flatFeePerMember       Decimal? // Alternative: flat fee per member
  commissionStructure    Json? // Complex tiered structures

  groups              Group[]
  commissions         Commission[]
  producers           BrokerProducer[]
  commissionSchedules BrokerCommissionSchedule[]
  commissionLedger    CommissionLedgerEntry[]
  kycDocuments        BrokerKycDocument[]
  documents           Document[]
  user                User?
  quotations          Quotation[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, intermediaryCategory])
  @@index([tenantId, canReceiveCommission])
  @@index([status, effectiveFrom, effectiveTo])
  @@index([parentBrokerId])
}

model BrokerKycDocument {
  id           String            @id @default(cuid())
  brokerId     String
  broker       Broker            @relation(fields: [brokerId], references: [id])
  documentType KycDocumentType
  fileUri      String
  fileName     String
  uploadedAt   DateTime          @default(now())
  uploadedById String
  verifiedAt   DateTime?
  verifiedById String?
  expiresAt    DateTime?
  status       KycDocumentStatus @default(PENDING_REVIEW)
  notes        String?

  @@index([brokerId, documentType])
  @@index([status, expiresAt])
}

model BrokerProducer {
  id                  String    @id @default(cuid())
  brokerId            String
  broker              Broker    @relation(fields: [brokerId], references: [id])
  producerName        String
  producerCode        String    @unique
  iraIndividualNumber String?
  email               String
  phone               String
  effectiveFrom       DateTime
  effectiveTo         DateTime?
  status              String    @default("ACTIVE")
  groups              Group[]   @relation("ProducerSchemes")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brokerId, status])
}

model BrokerCommissionSchedule {
  id                     String                  @id @default(cuid())
  brokerId               String
  broker                 Broker                  @relation(fields: [brokerId], references: [id])
  scheduleName           String
  scheduleType           CommissionScheduleType
  packageId              String?
  groupId                String?
  clientType             ClientType?
  newBusinessRate        Decimal                 @db.Decimal(8, 5)
  renewalRate            Decimal                 @db.Decimal(8, 5)
  overrideRate           Decimal?                @db.Decimal(8, 5)
  grossCommissionCeiling Decimal?                @db.Decimal(8, 5)
  payoutCycleDays        Int                     @default(30)
  tiers                  CommissionTier[]
  effectiveFrom          DateTime
  effectiveTo            DateTime?
  status                 ScheduleStatus          @default(DRAFT)
  createdById            String
  approvedById           String?
  approvedAt             DateTime?
  ledgerEntries          CommissionLedgerEntry[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([brokerId, effectiveFrom, effectiveTo])
  @@index([brokerId, status])
  @@index([groupId])
  @@index([packageId])
}

model CommissionTier {
  id              String                   @id @default(cuid())
  scheduleId      String
  schedule        BrokerCommissionSchedule @relation(fields: [scheduleId], references: [id])
  tierOrder       Int
  thresholdMetric TierMetric
  thresholdMin    Decimal                  @db.Decimal(18, 2)
  thresholdMax    Decimal?                 @db.Decimal(18, 2)
  rate            Decimal                  @db.Decimal(8, 5)

  @@index([scheduleId, tierOrder])
}

model CommissionLedgerEntry {
  id                    String                    @id @default(cuid())
  brokerId              String
  broker                Broker                    @relation(fields: [brokerId], references: [id])
  scheduleId            String?
  schedule              BrokerCommissionSchedule? @relation(fields: [scheduleId], references: [id])
  groupId               String
  contributionReceiptId String?
  membershipId          String?
  state                 CommissionState
  stateAsOf             DateTime                  @default(now())
  grossCommission       Decimal                   @db.Decimal(18, 2)
  withholdingTax        Decimal                   @db.Decimal(18, 2)
  vatAmount             Decimal                   @db.Decimal(18, 2)
  iraAgentLevy          Decimal                   @db.Decimal(18, 2)
  netPayable            Decimal                   @db.Decimal(18, 2)
  currency              String                    @default("KES")
  earnedPeriodStart     DateTime
  earnedPeriodEnd       DateTime
  paidAt                DateTime?
  paymentReference      String?
  payoutBatchId         String?
  payoutBatch           CommissionPayoutBatch?    @relation(fields: [payoutBatchId], references: [id])
  clawbackParentId      String?
  clawbackParent        CommissionLedgerEntry?    @relation("ClawbackChain", fields: [clawbackParentId], references: [id])
  clawbackChildren      CommissionLedgerEntry[]   @relation("ClawbackChain")
  clawbackReason        String?
  notes                 String?
  createdAt             DateTime                  @default(now())

  @@index([brokerId, state, earnedPeriodStart])
  @@index([groupId, earnedPeriodStart])
  @@index([payoutBatchId])
  @@index([contributionReceiptId])
}

model CommissionPayoutBatch {
  id             String                  @id @default(cuid())
  batchReference String                  @unique
  batchDate      DateTime
  totalGross     Decimal                 @db.Decimal(18, 2)
  totalWHT       Decimal                 @db.Decimal(18, 2)
  totalVAT       Decimal                 @db.Decimal(18, 2)
  totalLevy      Decimal                 @db.Decimal(18, 2)
  totalNet       Decimal                 @db.Decimal(18, 2)
  currency       String                  @default("KES")
  status         PayoutBatchStatus
  generatedById  String
  approvedById   String?
  approvedAt     DateTime?
  disbursedAt    DateTime?
  entries        CommissionLedgerEntry[]
  createdAt      DateTime                @default(now())

  @@index([status, batchDate])
}

model Commission {
  id                   String    @id @default(cuid())
  brokerId             String
  broker               Broker    @relation(fields: [brokerId], references: [id])
  period               String // "2025-03" (year-month)
  groupId              String?
  contributionReceived Decimal
  commissionRate       Decimal // The applicable rate
  commissionAmount     Decimal
  paymentStatus        String    @default("PENDING") // PENDING, APPROVED, PAID
  paidAt               DateTime?
  paymentReference     String?
  createdAt            DateTime  @default(now())

  @@index([brokerId])
  @@index([brokerId, period])
}

// ─── BILLING & FINANCE ──────────────────────────────────
enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

model Invoice {
  currency      String        @default("UGX") // G3.5 multi-currency (base UGX)
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  invoiceNumber String // e.g., INV-2025-00001
  groupId       String
  group         Group         @relation(fields: [groupId], references: [id])
  period        String // "2025-03"
  memberCount   Int
  ratePerMember Decimal
  totalAmount   Decimal
  paidAmount    Decimal       @default(0)
  balance       Decimal // totalAmount - paidAmount
  // Kenyan statutory taxes — computed at invoice generation
  stampDuty     Decimal       @default(40) @db.Decimal(10, 2) // KES 40 flat
  trainingLevy  Decimal       @default(0) @db.Decimal(10, 2) // 0.2% of basic premium
  phcf          Decimal       @default(0) @db.Decimal(10, 2) // 0.25% of basic premium
  taxTotal      Decimal       @default(0) @db.Decimal(10, 2) // stampDuty + trainingLevy + phcf
  dueDate       DateTime
  status        InvoiceStatus @default(DRAFT)
  sentAt        DateTime?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payments Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([groupId])
  @@index([groupId, status])
}

model Payment {
  currency        String    @default("UGX") // G3.5 multi-currency (base UGX)
  id              String    @id @default(cuid())
  groupId         String
  group           Group     @relation(fields: [groupId], references: [id])
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  amount          Decimal
  paymentDate     DateTime
  paymentMethod   String // BANK_TRANSFER, CHEQUE, MPESA, CARD
  referenceNumber String?
  notes           String?
  reconciledAt    DateTime?
  createdAt       DateTime  @default(now())

  @@index([groupId])
  @@index([invoiceId])
}

model PaymentVoucher {
  id            String    @id @default(cuid())
  voucherNumber String
  tenantId      String? // PR-018: tenant scope (nullable for legacy rows)
  providerId    String
  totalAmount   Decimal
  // OBS-2 Ticket 4/6: denomination of totalAmount + UGX base equivalent.
  currency        String  @default("UGX")
  baseCurrency    String  @default("UGX")
  baseTotalAmount Decimal @default(0) @db.Decimal(19, 4)
  claimCount    Int
  status        String    @default("PENDING") // PENDING, APPROVED, PROCESSED
  processedAt   DateTime?
  processedBy   String?
  createdAt     DateTime  @default(now())

  // PR-018 #2: batch ↔ voucher ↔ JE cross-links, resolvable both ways.
  // One-voucher-per-batch is enforced by the settlement status machine
  // (markSettlementBatchPaid only runs on CHECKER_APPROVED and flips the batch
  // to SETTLED in the same transaction) — a plain index keeps `prisma db push`
  // warning-free so the Vercel production build's schema sync can apply it.
  settlementBatchId String?
  journalEntryId    String?

  claims Claim[]

  @@index([tenantId])
  @@index([providerId])
  @@index([settlementBatchId])
}

// ─── QUOTATIONS ─────────────────────────────────────────
enum QuotationStatus {
  // Pre-issuance assessment stages (Process 3)
  PENDING_VALIDATION
  PENDING_ASSESSMENT
  ASSESSED
  ASSESSED_PENDING_SENIOR_APPROVAL
  DECLINED_BY_UNDERWRITING
  WITHDRAWN_BY_SUBMITTER
  // Post-assessment issuance stages
  DRAFT
  SENT
  REVISED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum UWDecisionType {
  STANDARD
  LOADED
  EXCLUSION
  WAITING_PERIOD
  DECLINED
}

enum LifeRole {
  PRINCIPAL
  DEPENDANT
}

model Quotation {
  currency    String  @default("UGX") // G3.5 multi-currency (base UGX)
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id])
  quoteNumber String // e.g., QUO-2025-00001
  groupId     String? // If quoting for existing group (renewal)
  group       Group?  @relation(fields: [groupId], references: [id])
  brokerId    String? // If submitted by broker
  broker      Broker? @relation(fields: [brokerId], references: [id])
  createdBy   String // User ID

  // Prospect info (if new group / no groupId yet)
  prospectName     String?
  prospectContact  String?
  prospectEmail    String?
  prospectIndustry String?

  // ── Assessment-stage fields (Process 3) ──────────────────
  clientType          ClientType? // CORPORATE | INDIVIDUAL
  fundingMode         FundingMode @default(INSURED) // INSURED=contribution-bearing, SELF_FUNDED=fund-managed
  headcount           Int? // Corporate: declared headcount
  legalName           String? // Corporate: legal entity name
  kraPinCorporate     String?
  billingContactEmail String?
  requestedCoverStart DateTime?
  censusFileUrl       String? // Uploaded CSV/Excel for corporate census

  // Workflow / maker-checker
  assignedAssessorId    String?
  assessorSlaDeadlineAt DateTime?
  assessorNotes         String?
  seniorApprovalNote    String?
  declineReason         String?

  // Renewal linkage
  isRenewal        Boolean @default(false)
  priorQuotationId String?

  // ── Pricing fields (nullable until assessment complete) ───
  packageId      String?
  memberCount    Int             @default(0)
  dependentCount Int             @default(0)
  ageBands       Json? // [{ minAge, maxAge, count, rate }]
  ratePerMember  Decimal?        @db.Decimal(14, 2)
  annualPremium  Decimal?        @db.Decimal(14, 2)
  loadings       Json? // { claimsHistory: 15, industry: 5 }
  discounts      Json? // { groupSize: -10, loyaltyYears: -5 }
  finalPremium   Decimal?        @db.Decimal(14, 2)
  pricingNotes   String?
  validUntil     DateTime?
  status         QuotationStatus @default(DRAFT)

  // If using uploaded pricing model
  pricingModelId String?
  pricingModel   PricingModel? @relation(fields: [pricingModelId], references: [id])

  // ── Assessment-stage relations ────────────────────────────
  lives         QuotationLife[]
  decisions     UnderwritingDecision[]
  riskProfile   QuotationRiskProfile?
  workQueueItem AssessorWorkQueueItem?
  assessor      User?                  @relation("QuotationAssessor", fields: [assignedAssessorId], references: [id])
  // ── Pricing & issuance relations ──────────────────────────
  versions      QuotationVersion[]
  lineItems     QuotationLineItem[]
  acceptance    QuotationAcceptance?

  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedAssessorId])
}

model PricingModel {
  id          String   @id @default(cuid())
  tenantId    String
  name        String // "Standard Flat Rate", "Age-Banded Model 2025"
  description String?
  type        String // FLAT_RATE, AGE_BANDED, EXPERIENCE_RATED, CUSTOM
  fileUrl     String? // Uploaded Excel/Python pricing model
  parameters  Json // Structured pricing parameters
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotations Quotation[]
  rateTables ContributionRateTable[]
}

model ContributionRateTable {
  id             String       @id @default(cuid())
  pricingModelId String
  pricingModel   PricingModel @relation(fields: [pricingModelId], references: [id], onDelete: Cascade)
  minAge         Int
  maxAge         Int
  gender         String
  familySize     String
  location       String?
  baseRate       Decimal      @db.Decimal(14, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([pricingModelId])
  @@index([pricingModelId, minAge, maxAge])
}

// ─── SUPPORTING ENTITIES ────────────────────────────────

model Document {
  id            String            @id @default(cuid())
  fileName      String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  category      String // INVOICE, LAB_RESULT, DISCHARGE_SUMMARY, AGREEMENT, MEMBER_LIST, TARIFF_SCHEDULE, CLAIM_SUPPORT, ENDORSEMENT, QUOTATION
  uploadedBy    String?
  // Polymorphic relation via nullable FKs
  groupId       String?
  group         Group?            @relation(fields: [groupId], references: [id])
  endorsementId String?
  endorsement   Endorsement?      @relation(fields: [endorsementId], references: [id])
  claimId       String?
  claim         Claim?            @relation(fields: [claimId], references: [id])
  preauthId     String?
  preauth       PreAuthorization? @relation(fields: [preauthId], references: [id])
  caseId        String?
  case          ClinicalCase?     @relation(fields: [caseId], references: [id])
  brokerId      String?
  broker        Broker?           @relation(fields: [brokerId], references: [id])
  quotationId   String?
  quotation     Quotation?        @relation(fields: [quotationId], references: [id])
  createdAt     DateTime          @default(now())
}

model Correspondence {
  id       String   @id @default(cuid())
  memberId String
  member   Member   @relation(fields: [memberId], references: [id])
  type     String // WELCOME, CARD_ISSUED, CLAIM_UPDATE, RENEWAL_REMINDER, SUSPENSION_NOTICE, PREAUTH_STATUS
  channel  String // EMAIL, SMS, BOTH
  subject  String?
  body     String?
  status   String   @default("SENT") // SENT, FAILED, PENDING
  sentAt   DateTime @default(now())
}

// WP-7 (FULL GO closure): the background worker's liveness, readable by the
// web app — the Redis heartbeat key is invisible to Vercel, so the worker
// also upserts one row per host here every 60s. /api/health reports the
// freshest row (workerFresh = seen within 5 minutes).
model WorkerHeartbeat {
  id         String   @id @default(cuid())
  host       String   @unique
  startedAt  DateTime
  lastSeenAt DateTime

  @@index([lastSeenAt])
}

model ActivityLog {
  id          String   @id @default(cuid())
  entityType  String // GROUP, MEMBER, CLAIM, PREAUTH, ENDORSEMENT
  entityId    String
  action      String // CREATED, UPDATED, STATUS_CHANGED, PAYMENT_RECEIVED, etc.
  description String
  userId      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Polymorphic references
  groupId       String?
  group         Group?            @relation(fields: [groupId], references: [id])
  memberId      String?
  member        Member?           @relation(fields: [memberId], references: [id])
  endorsementId String?
  endorsement   Endorsement?      @relation(fields: [endorsementId], references: [id])
  preauthId     String?
  preauth       PreAuthorization? @relation(fields: [preauthId], references: [id])

  @@index([entityType, entityId])
  @@index([groupId, createdAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  tenantId      String?
  action        String
  module        String
  description   String
  ipAddress     String?
  metadata      Json?
  // Chain fields — populated by audit-chain.service.ts
  entityType    String?
  entityId      String?
  payloadHash   String? // SHA-256 of canonical JSON payload
  previousHash  String? // payloadHash of the preceding entry in this tenant's chain
  chainSequence BigInt   @default(autoincrement())
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@index([tenantId, chainSequence])
  @@index([tenantId, entityType, entityId])
}

// ─── MEDICAL CODE REFERENCE ─────────────────────────────
model ICD10Code {
  code           String   @id // "E11.9"
  description    String // "Type 2 diabetes mellitus, unspecified"
  category       String // "Endocrine, nutritional and metabolic diseases"
  chapterCode    String? // "IV"
  standardCharge Decimal? // Standard consultation/admission charge in KES for this diagnosis
}

model CPTCode {
  code            String   @id // "99213"
  description     String // "Office or other outpatient visit, established patient"
  category        String // "Evaluation and Management"
  serviceCategory String   @default("CONSULTATION") // CONSULTATION, LABORATORY, PHARMACY, IMAGING, PROCEDURE, OTHER
  averageCost     Decimal? // Reference cost in KES — used when no provider tariff exists
}

// ─── NOTIFICATION TEMPLATES ─────────────────────────────
model NotificationTemplate {
  id           String   @id @default(cuid())
  tenantId     String
  name         String // "Welcome Email"
  type         String // WELCOME, CARD_ISSUED, CLAIM_APPROVED, CLAIM_DECLINED, RENEWAL_REMINDER_30, RENEWAL_REMINDER_7, PAYMENT_OVERDUE, SUSPENSION_NOTICE
  channel      String // EMAIL, SMS, BOTH
  subject      String? // For email
  bodyTemplate String // Template with {{variables}}
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── EXCEPTION LOGS ─────────────────────────────────────

enum ExceptionStatus {
  PENDING
  APPROVED
  REJECTED
}

model ExceptionLog {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  entityType String // CLAIM | PREAUTH | CLAIM_LINE | INVOICE
  entityId   String // id of the affected record
  entityRef  String? // Human-readable ref e.g. "CLM-2025-00001"

  // Polymorphic claim link (optional — for quick JOIN)
  claimId String?
  claim   Claim?  @relation("ClaimExceptions", fields: [claimId], references: [id])

  exceptionCode String // BENEFIT_EXCEEDED | MANUAL_OVERRIDE | LATE_SUBMISSION | PROVIDER_RATE_DISPUTE | FRAUD_INVESTIGATION | DUPLICATE_CHECK | OTHER
  reason        String
  notes         String?

  raisedById String
  raisedBy   User   @relation("ExceptionRaisedBy", fields: [raisedById], references: [id])

  status         ExceptionStatus @default(PENDING)
  resolvedById   String?
  resolvedBy     User?           @relation("ExceptionResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?
  resolutionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([entityType, entityId])
  @@index([claimId])
}

// ─── GENERAL LEDGER ──────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum JournalStatus {
  POSTED
  REVERSED
}

enum GLSourceType {
  INVOICE_ISSUED
  PREMIUM_RECEIVED
  CLAIM_APPROVED
  CLAIM_PAID
  CLAIM_VOID // PR-018 D3: reversing JE when an approved claim is voided
  SETTLEMENT_PAID // PR-018 D1: batch Mark Paid — Dr Claims Payable / Cr Bank
  COMMISSION_EARNED
  ENDORSEMENT_ADJUSTMENT
  CO_CONTRIBUTION_COLLECTED
  CO_CONTRIBUTION_WAIVED
  MANUAL
}

model ChartOfAccount {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  code          String // e.g. "1100"
  name          String // e.g. "Premium Receivables"
  type          AccountType
  subtype       String? // e.g. "Current Assets"
  normalBalance NormalBalance
  description   String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  journalLines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, type])
}

model JournalEntry {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  entryNumber  String // "JE-2025-00001"
  entryDate    DateTime
  description  String
  reference    String? // Invoice / claim / payment ref
  sourceType   GLSourceType
  sourceId     String? // ID of triggering record
  status       JournalStatus @default(POSTED)
  postedById   String?
  isReversed   Boolean       @default(false)
  reversalOfId String? // Set on the reversal entry; points back to original

  lines     JournalLine[]
  createdAt DateTime      @default(now())

  @@unique([tenantId, entryNumber])
  @@index([tenantId])
  @@index([tenantId, sourceType, sourceId])
  @@index([entryDate])
  @@index([tenantId, status])
}

model JournalLine {
  id             String         @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id])
  accountId      String
  account        ChartOfAccount @relation(fields: [accountId], references: [id])
  description    String?
  debit          Decimal        @default(0)
  credit         Decimal        @default(0)

  @@index([journalEntryId])
  @@index([accountId])
}

// ─── INTEGRATION CONFIG ─────────────────────────────────
model IntegrationConfig {
  id         String    @id @default(cuid())
  tenantId   String
  provider   String // SMART, SLADE360, HMS, SHA, ERP
  isEnabled  Boolean   @default(false)
  apiBaseUrl String?
  apiKey     String? // Encrypted
  apiSecret  String? // Encrypted
  config     Json      @default("{}")
  lastSyncAt DateTime?
  status     String    @default("DISCONNECTED") // CONNECTED, DISCONNECTED, ERROR
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([tenantId, provider])
}

// ─── FRAUD ALERTS ────────────────────────────────────────

enum FraudSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model ClaimFraudAlert {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  claimId    String
  claim      Claim         @relation(fields: [claimId], references: [id])
  rule       String // e.g. "Velocity Check", "Unauth High Value"
  score      Int // Severity confidence (1-100)
  severity   FraudSeverity @default(MEDIUM)
  notes      String?
  resolved   Boolean       @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@index([tenantId])
  @@index([claimId])
  @@index([resolved])
}

// ─── COMPLAINTS ──────────────────────────────────────────

enum ComplaintStatus {
  OPEN
  INVESTIGATING
  RESOLVED
  DISMISSED
}

model Complaint {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  memberId    String?
  member      Member?         @relation(fields: [memberId], references: [id])
  subject     String
  type        String // e.g. "SERVICE", "FACILITY", "BILLING"
  description String
  status      ComplaintStatus @default(OPEN)
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tenantId])
  @@index([memberId])
  @@index([status])
}

// ─── CO-CONTRIBUTION ────────────────────────────────────────────────────────

enum CoContributionType {
  FIXED_AMOUNT // Flat KES amount per encounter
  PERCENTAGE // % of eligible cost
  HYBRID // Fixed minimum OR percentage, whichever is greater
  NONE // Exempt service — zero co-contribution
}

// Maps to Provider.tier: OWN → TIER_1, PARTNER/PANEL → TIER_2, unknown → TIER_3
enum NetworkTier {
  TIER_1 // Medvex own facilities
  TIER_2 // Contracted partner / panel
  TIER_3 // Out-of-network
}

enum CoContributionCollectionStatus {
  PENDING
  COLLECTED
  PARTIAL
  WAIVED
  DEFERRED
  REFUNDED
  WRITTEN_OFF
}

enum CoContributionPaymentMethod {
  CASH
  MPESA
  CARD
  BANK_TRANSFER
  OFFSET
}

enum MemberCoContributionPaymentStatus {
  INITIATED
  PENDING_CALLBACK
  CONFIRMED
  FAILED
  TIMED_OUT
  CANCELLED
}

// One rule per (package × benefit category × network tier × effective period)
// benefitCategory == null means package-wide default for that tier
model CoContributionRule {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  packageId String
  package   Package @relation(fields: [packageId], references: [id])
  // Per-client copay override (G3.4/G5.7): null = package rule; set = this
  // client's rule (wins over the package rule at resolution).
  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id])

  benefitCategory BenefitCategory? // null = package-wide default
  networkTier     NetworkTier        @default(TIER_1)
  type            CoContributionType

  fixedAmount     Decimal? @db.Decimal(12, 2) // FIXED_AMOUNT or HYBRID minimum
  percentage      Decimal? @db.Decimal(5, 2) // PERCENTAGE or HYBRID (e.g. 20.00 = 20%)
  perVisitCap     Decimal? @db.Decimal(12, 2) // Max co-contribution per encounter
  perEncounterCap Decimal? @db.Decimal(12, 2) // Max per individual service line

  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  coContributionTransactions CoContributionTransaction[]

  @@index([tenantId])
  @@index([packageId])
  @@index([packageId, benefitCategory, networkTier])
  @@index([clientId])
}

// Per-package annual out-of-pocket caps (individual + optional family)
model AnnualCoContributionCap {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  packageId String  @unique
  package   Package @relation(fields: [packageId], references: [id])

  individualCap Decimal  @db.Decimal(12, 2)
  familyCap     Decimal? @db.Decimal(12, 2) // null = no family cap

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
}

// One record per claim — the financial detail of a single co-contribution event
model CoContributionTransaction {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  claimId              String              @unique
  claim                Claim               @relation(fields: [claimId], references: [id])
  memberId             String
  member               Member              @relation(fields: [memberId], references: [id])
  coContributionRuleId String?
  coContributionRule   CoContributionRule? @relation(fields: [coContributionRuleId], references: [id])

  serviceCost      Decimal  @db.Decimal(12, 2) // Eligible service cost
  calculatedAmount Decimal  @db.Decimal(12, 2) // Raw calculation before caps
  cappedAmount     Decimal  @db.Decimal(12, 2) // After per-visit / per-encounter cap
  annualCapApplied Boolean  @default(false)
  finalAmount      Decimal  @db.Decimal(12, 2) // What member actually owes
  planShare        Decimal  @db.Decimal(12, 2) // What plan covers
  amountCollected  Decimal  @default(0) @db.Decimal(12, 2)
  capsApplied      String[] // Which caps were binding

  collectionStatus    CoContributionCollectionStatus @default(PENDING)
  paymentMethod       CoContributionPaymentMethod?
  mpesaTransactionRef String?
  mpesaPhoneNumber    String?
  receiptNumber       String?
  paymentAttempts     MemberCoContributionPayment[]

  waiverReason     String?
  waiverApprovedBy String?
  waiverApprovedAt DateTime?

  calculatedAt DateTime  @default(now())
  collectedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?

  @@index([tenantId])
  @@index([memberId])
  @@index([collectionStatus])
}

model MemberCoContributionPayment {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  memberId String
  member   Member @relation(fields: [memberId], references: [id])

  coContributionTransactionId String
  coContributionTransaction   CoContributionTransaction @relation(fields: [coContributionTransactionId], references: [id])

  amount         Decimal                           @db.Decimal(12, 2)
  phoneNumber    String
  status         MemberCoContributionPaymentStatus @default(INITIATED)
  idempotencyKey String

  checkoutRequestId String  @unique
  merchantRequestId String?
  mpesaReceipt      String?
  resultCode        String?
  resultDescription String?

  requestedAt DateTime  @default(now())
  confirmedAt DateTime?
  failedAt    DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([memberId])
  @@index([coContributionTransactionId])
  @@index([status])
  @@index([expiresAt])
}

// Running annual total per member (updated on each co-contribution event)
model MemberAnnualCoContribution {
  id             String @id @default(cuid())
  tenantId       String
  tenant         Tenant @relation(fields: [tenantId], references: [id])
  memberId       String
  member         Member @relation(fields: [memberId], references: [id])
  membershipYear Int // e.g. 2026

  totalCoContribution Decimal   @default(0) @db.Decimal(12, 2)
  capReached          Boolean   @default(false)
  capReachedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([memberId, membershipYear])
  @@index([tenantId])
}

// Running annual total for the family unit (principal + dependents)
model FamilyAnnualCoContribution {
  id                String @id @default(cuid())
  tenantId          String
  tenant            Tenant @relation(fields: [tenantId], references: [id])
  principalMemberId String
  principal         Member @relation("FamilyCoContributions", fields: [principalMemberId], references: [id])
