model ProviderSettlementBatch {
  id          String           @id @default(cuid())
  tenantId    String
  providerId  String
  cycleMonth  Int
  cycleYear   Int
  // BD-05: multiple settlement runs per provider+cycle. Run 1 is the normal
  // monthly batch; later-approved claims for the same cycle settle in a
  // supplementary run (sequence 2, 3, …). Existing rows default to 1.
  sequence    Int              @default(1)
  status      SettlementStatus @default(PENDING)
  totalAmount Decimal          @default(0) @db.Decimal(19, 4)
  // OBS-2 Ticket 4: every batch settles in ONE transaction currency (mixed
  // currencies are blocked at creation). `baseTotalAmount` carries the UGX
  // equivalent for base-currency GL/reporting (populated in Ticket 6).
  currency        String  @default("UGX")
  baseCurrency    String  @default("UGX")
  baseTotalAmount Decimal @default(0) @db.Decimal(19, 4)
  claimCount  Int              @default(0)
  makerId     String
  checkerId   String?
  settledAt   DateTime?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  provider Provider @relation(fields: [providerId], references: [id])
  claims   Claim[]

  @@unique([tenantId, providerId, cycleMonth, cycleYear, sequence])
  @@index([tenantId, status])
  @@index([tenantId, providerId])
}

// ─── REIMBURSEMENT (Process 10) ──────────────────────────

enum ProofType {
  RECEIPT_PHOTO
  MPESA_SMS
  BANK_STATEMENT
  OTHER
}

enum ReimbursementPaymentMethod {
  BANK_TRANSFER
  MPESA
}

model ReimbursementRequest {
  id                      String                      @id @default(cuid())
  tenantId                String
  claimId                 String                      @unique
  memberId                String
  providerName            String
  serviceDate             DateTime
  totalPaidByMember       Decimal                     @db.Decimal(19, 4)
  proofType               ProofType
  proofFileUrl            String
  mpesaConfirmationCode   String?
  mpesaVerified           Boolean                     @default(false)
  // Stub note — surfaced to reviewer when M-Pesa Daraja not yet integrated
  mpesaNote               String?
  submittedWithinWindow   Boolean                     @default(true)
  reimbursementWindowDays Int                         @default(90)
  disbursementMethod      ReimbursementPaymentMethod?
  disbursedAt             DateTime?
  disbursementRef         String?
  createdAt               DateTime                    @default(now())

  claim Claim @relation(fields: [claimId], references: [id])

  @@index([tenantId, memberId])
}

// ─── RBAC — ROLES & PERMISSIONS ──────────────────────────
// Replaces the flat UserRole enum for permission-level checks.
// UserRole enum is kept on User for backward-compat during transition.

model Role {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  code         String // e.g. "UNDERWRITER", "SENIOR_UNDERWRITER"
  isSystemRole Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  permissions RolePermission[]
  assignments UserRoleAssignment[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model Permission {
  id          String @id @default(cuid())
  code        String @unique // e.g. "QUOTATION:ISSUE"
  module      String // e.g. "QUOTATION", "CLAIM"
  action      String // e.g. "CREATE", "APPROVE"
  resource    String // e.g. "QUOTATION", "CLAIM"
  description String

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  grantedAt    DateTime @default(now())
  grantedById  String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

enum RoleAssignmentStatus {
  PENDING_APPROVAL
  ACTIVE
  REVOKED
  EXPIRED
}

model UserRoleAssignment {
  id          String               @id @default(cuid())
  userId      String
  roleId      String
  tenantId    String
  assignedAt  DateTime             @default(now())
  expiresAt   DateTime?
  isActive    Boolean              @default(true)
  revokedAt   DateTime?
  revokedById String?
  // Maker-checker: role assignment itself requires two-person approval (spec §13)
  makerId     String
  checkerId   String?
  status      RoleAssignmentStatus @default(PENDING_APPROVAL)

  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, userId, isActive])
  @@index([tenantId, status])
  @@index([roleId])
}

