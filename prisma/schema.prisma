// ─── MEMBERS ─────────────────────────────────────────────
enum MemberStatus {
  PENDING_ACTIVATION
  ACTIVE
  SUSPENDED
  LAPSED
  LAPSED_BEFORE_ACTIVATION // bound but first contribution never received
  TERMINATED
  CANCELLED_COOLING_OFF // Process 12: cancelled within cooling-off window
  TERMINATED_FRAUD // Process 12: fraud-confirmed termination
  TERMINATED_BREACH // Process 12: terms breach termination
  TERMINATED_DEATH // Process 12: principal death
  EXPIRED // cover period ended without renewal
}

enum MemberRelationship {
  PRINCIPAL
  SPOUSE
  CHILD
  PARENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Member {
  id                     String             @id @default(cuid())
  tenantId               String
  tenant                 Tenant             @relation(fields: [tenantId], references: [id])
  memberNumber           String // e.g., AVH-2024-00001
  groupId                String
  group                  Group              @relation(fields: [groupId], references: [id])
  firstName              String
  lastName               String
  otherNames             String?
  idNumber               String? // National ID / Passport
  dateOfBirth            DateTime
  gender                 Gender
  phone                  String?
  email                  String?
  photoUrl               String?
  relationship           MemberRelationship @default(PRINCIPAL)
  principalId            String? // If dependent, links to principal member
  principal              Member?            @relation("Dependents", fields: [principalId], references: [id])
  dependents             Member[]           @relation("Dependents")
  packageId              String // Inherited from group tier or set directly
  package                Package            @relation(fields: [packageId], references: [id])
  packageVersionId       String?
  packageVersion         PackageVersion?    @relation(fields: [packageVersionId], references: [id])
  benefitTierId          String? // Optional: links to a GroupBenefitTier
  benefitTier            GroupBenefitTier?  @relation(fields: [benefitTierId], references: [id])
  enrollmentDate         DateTime
  activationDate         DateTime?
  coverStartDate         DateTime? // set during binding (may differ from activationDate)
  coverEndDate           DateTime?
  status                 MemberStatus       @default(PENDING_ACTIVATION)
  waitingPeriodEnd       DateTime? // General waiting period end
  smartCardNumber        String? // SMART card number if integrated
  slade360MemberId       String? // Slade360 member ID if integrated
  // Binding provenance
  underwritingDecisionId String? // links to UnderwritingDecision applied to this member
  bindingMakerId         String?
  bindingCheckerId       String?
  quotationId            String? // source quotation
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  claims                         Claim[]
  preauths                       PreAuthorization[]
  benefitUsages                  BenefitUsage[]
  endorsements                   Endorsement[]                    @relation("EndorsementMember")
  complaints                     Complaint[]
  coContributionTransactions     CoContributionTransaction[]
  coContributionPayments         MemberCoContributionPayment[]
  annualCoContributions          MemberAnnualCoContribution[]
  familyCoContributions          FamilyAnnualCoContribution[]     @relation("FamilyCoContributions")
  user                           User?
  correspondences                Correspondence[]
  activityLogs                   ActivityLog[]
  webAuthnCredentials            MemberWebAuthnCredential[]
  webAuthnRegistrationChallenges WebAuthnRegistrationChallenge[]
  webAuthnEnrollmentApprovals    WebAuthnEnrollmentApproval[]
  checkInChallenges              CheckInChallenge[]
  checkInEvents                  CheckInEvent[]
  checkInNotifications           MemberCheckInNotification[]
  notifications                  MemberNotification[]
  healthFiles                    MemberHealthFile[]
  vitalEntries                   MemberVitalEntry[]
  healthJournalEntries           MemberHealthJournalEntry[]
  healthShares                   MemberHealthShare[]
  visitVerifications             VisitVerification[]
  reinstatementRequests          MembershipReinstatementRequest[]
  crossBorderCases               CrossBorderCase[]
  wellnessEnrollments            WellnessEnrollment[]
  wellnessActivities             WellnessActivity[]
  clinicalCases                  ClinicalCase[]
  lettersOfUndertaking           LetterOfUndertaking[]
  coveragePeriods                MemberCoveragePeriod[]

  @@unique([tenantId, memberNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, enrollmentDate])
  @@index([groupId])
  @@index([groupId, status, enrollmentDate])
  @@index([principalId])
  @@index([idNumber])
}

// ─── POINT-IN-TIME COVERAGE (FG-C5) ─────────────────────
// Coverage history as explicit periods, so eligibility can ask "was the member
// covered ON the service date" instead of resolving by current status. A member
// has one open period (endDate NULL) while active; termination/expiry/lapse
// closes it (endDate = effective date); reinstatement opens a new one. Supports
// gaps and re-enrolment (multiple non-overlapping periods).
model MemberCoveragePeriod {
  id        String    @id @default(cuid())
  tenantId  String
  memberId  String
  startDate DateTime
  endDate   DateTime? // null = currently open / covered
  reason    String? // BINDING | ACTIVATION | REINSTATEMENT | TERMINATED | EXPIRED | LAPSED | BACKFILL
  createdAt DateTime  @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId, startDate])
  @@index([tenantId, memberId])
}

