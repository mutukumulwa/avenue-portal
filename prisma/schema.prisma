  terminologyApprovals           TerminologyApproval[]
  approvalRequests               ApprovalRequest[]
  fxRates                        FxRate[]
  syncOperations                 SyncOperation[]
  offlineReservations            OfflineReservation[]
  eligibilitySnapshots           EligibilitySnapshot[]
