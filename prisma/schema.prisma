// ── Cross-border / overseas care coordination (Medvex spec §5.15 / gap G5.15) ──
// AD-8 cross-border employee-benefits play. A coordination layer that sits on
// top of client pre-auth: vetted-facility sourcing → upfront estimate →
// GOP-within-limits commitment → single consolidated, audit-ready invoice.
// Foreign amounts are FX-normalised to the base currency (UGX, G3.5) at each
// step so limits, GOPs and invoices are all comparable and reportable. A
// per-case CROSS_BORDER coordination fee (G2.3) accrues on settlement.
enum CrossBorderCaseStatus {
  SOURCING // facility being sourced/vetted; no estimate yet
  ESTIMATED // upfront estimate captured & FX-normalised
  GOP_ISSUED // guarantee of payment committed within limits
  IN_TREATMENT // member receiving care
  INVOICED // consolidated invoice raised
  SETTLED // paid & coordination fee accrued
  CANCELLED // abandoned (never deleted)
}

enum CrossBorderLineKind {
  ESTIMATE // pre-treatment cost estimate line
  INVOICE // post-treatment consolidated-invoice line
}

// A vetted overseas/cross-border facility Medvex can steer cases to. Never
// deleted — retired facilities are closed with `effectiveTo` / `isActive`.
model CrossBorderFacility {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  country       String // ISO country name (e.g. "India", "Kenya", "South Africa")
  city          String?
  currency      String   @default("UGX") // facility's billing currency
  specialties   String[] // e.g. ["Oncology", "Cardiac Surgery"]
  accreditation String? // e.g. "JCI", "NABH"
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  notes         String?
  isVetted      Boolean  @default(false) // passed Medvex clinical/commercial vetting

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cases CrossBorderCase[]

  @@index([tenantId, isActive])
  @@index([tenantId, country])
}

// A single cross-border coordination episode for one member. Carries the FX
// snapshots for the estimate, the GOP commitment and the final invoice so the
// audit trail is self-contained.
model CrossBorderCase {
  id         String               @id @default(cuid())
  tenantId   String
  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  clientId   String // the paying client (payer)
  client     Client               @relation(fields: [clientId], references: [id])
  memberId   String
  member     Member               @relation(fields: [memberId], references: [id])
  facilityId String?
  facility   CrossBorderFacility? @relation(fields: [facilityId], references: [id])
  preauthId  String? // links into client pre-auth when coordinated from there

  caseNumber       String
  diagnosis        String
  treatmentSummary String?
  status           CrossBorderCaseStatus @default(SOURCING)

  // Estimate snapshot (base = UGX)
  estimatedAmount    Decimal?
  estimatedCurrency  String?
  estimatedAmountUgx Decimal?

  // GOP commitment snapshot (base = UGX) + limit check
  gopAmount        Decimal?
  gopCurrency      String?
  gopAmountUgx     Decimal?
  approvedLimitUgx Decimal? // member/benefit limit the GOP was checked against
  gopWithinLimit   Boolean? // true when gopAmountUgx <= approvedLimitUgx

  // Consolidated invoice snapshot
  invoiceReference String?
  invoiceTotalUgx  Decimal?
  invoicedAt       DateTime?
  settledAt        DateTime?

  adminFeeLedgerEntryId String? // CROSS_BORDER coordination fee accrued at settlement
  createdById           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems CrossBorderLineItem[]

  @@unique([tenantId, caseNumber])
  @@index([tenantId, clientId])
  @@index([tenantId, status])
  @@index([memberId])
  @@index([facilityId])
}

// Estimate and consolidated-invoice lines for a case, each FX-normalised to UGX
// at capture. The single consolidated invoice = the sum of kind=INVOICE lines.
model CrossBorderLineItem {
  id          String              @id @default(cuid())
  tenantId    String
  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  caseId      String
  case        CrossBorderCase     @relation(fields: [caseId], references: [id])
  kind        CrossBorderLineKind
  description String
  serviceDate DateTime?
  amount      Decimal
  currency    String
  fxRate      Decimal             @default(1) // rate used: amountUgx = amount × fxRate
  amountUgx   Decimal

  createdAt DateTime @default(now())

  @@index([caseId, kind])
  @@index([tenantId])
}

// ── Preventative care & wellness (Medvex spec §5.16 / gap G5.16) ───────────────
// AD-9 loss-ratio countermeasure. Three pillars in one configurable module:
//  • SCREENING — funded preventative checks configured into covers, recurring on
//    a cadence (annual health check, cervical/mammogram screening, etc.).
//  • CHRONIC_DISEASE_MGMT — enrolment into a managed protocol for target
//    conditions (diabetes, hypertension) with periodic checkpoints.
//  • INCENTIVE — activity tracking / gamification; members earn points that the
//    scheme can reward (premium discount, wellness credits).
// Members enrol into programmes; activities are logged against enrolments,
// awarding points and (for screenings) advancing the next-due date. Analytics
// feed the loss-ratio story.
enum WellnessProgramType {
  SCREENING // recurring funded preventative check
  CHRONIC_DISEASE_MGMT // managed protocol for a target condition
  INCENTIVE // activity/gamification points programme
}

enum WellnessEnrollmentStatus {
  ACTIVE
  COMPLETED // one-off screening done, or protocol graduated
  WITHDRAWN // member opted out (never deleted)
  LAPSED // missed the due window
}

enum WellnessActivityType {
  SCREENING_COMPLETED
  HEALTH_CHECK
  VITALS_LOGGED
  IMMUNIZATION
  COACHING_SESSION
  PHYSICAL_ACTIVITY
  OTHER
}

// A configurable wellness programme. Client-scoped when clientId is set,
// otherwise operator-wide. Never deleted — retire via effectiveTo / isActive.
model WellnessProgram {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  clientId String? // null = operator-wide default
  client   Client? @relation(fields: [clientId], references: [id])

  name        String
  type        WellnessProgramType
  description String?

  // SCREENING/CDM: months between checkpoints (null = one-off).
  cadenceMonths    Int?
  // SCREENING: amount funded into the cover per occurrence (FX per currency).
  fundedAmount     Decimal?
  currency         String   @default("UGX")
  // CHRONIC_DISEASE_MGMT: conditions this protocol manages.
  targetConditions String[]
  // INCENTIVE: default points awarded per qualifying activity.
  pointsReward     Int      @default(0)

  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments WellnessEnrollment[]

  @@index([tenantId, isActive])
  @@index([tenantId, clientId])
  @@index([tenantId, type])
}

// A member's enrolment into a programme. One active enrolment per member+program.
model WellnessEnrollment {
  id        String                   @id @default(cuid())
  tenantId  String
  tenant    Tenant                   @relation(fields: [tenantId], references: [id])
  programId String
  program   WellnessProgram          @relation(fields: [programId], references: [id])
  memberId  String
  member    Member                   @relation(fields: [memberId], references: [id])
  status    WellnessEnrollmentStatus @default(ACTIVE)

  enrolledAt     DateTime  @default(now())
  nextDueDate    DateTime? // next checkpoint (screenings/CDM)
  lastActivityAt DateTime?
  completedAt    DateTime?
  pointsEarned   Int       @default(0)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities WellnessActivity[]

  @@unique([tenantId, programId, memberId])
  @@index([tenantId, status])
  @@index([tenantId, nextDueDate])
  @@index([memberId])
}

// A logged wellness activity against an enrolment (drives points + due dates).
model WellnessActivity {
  id            String               @id @default(cuid())
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  enrollmentId  String
  enrollment    WellnessEnrollment   @relation(fields: [enrollmentId], references: [id])
  memberId      String
  member        Member               @relation(fields: [memberId], references: [id])
  type          WellnessActivityType
  description   String?
  activityDate  DateTime             @default(now())
  pointsAwarded Int                  @default(0)
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([enrollmentId])
  @@index([tenantId, memberId])
}

// ═══════════════════════════════════════════════════════════════════════════
// CLAIMS AUTOPILOT — canonical intake receipt (F2.1, plan §9.1–§9.2)
// Durable, payload-safe idempotency receipt: one row per intake attempt under a
// (tenant, scopeKey, channel, idempotencyKey) uniqueness boundary. Stores hashes
// and safe outcomes only — never raw payloads/credentials/clinical text (D16).
// ═══════════════════════════════════════════════════════════════════════════

enum ClaimIntakeChannel {
  ADMIN_PORTAL
  PROVIDER_PORTAL
  API_V1
  TRPC
  CSV_IMPORT
  OFFLINE_SYNC
  REIMBURSEMENT
  PREAUTH_CONVERSION
  CASE_INTERIM
  CASE_FINAL
  SMART
  SLADE360
}

enum ClaimIntakeReceiptState {
  PROCESSING
  SUCCEEDED
  REJECTED
  FAILED
}

model ClaimIntakeReceipt {
  id                            String                  @id @default(cuid())
  tenantId                      String
  tenant                        Tenant                  @relation(fields: [tenantId], references: [id])
  // Server-derived idempotency scope (user:<id> / provider:<id> / device:<p>:<d>
  // / case:<id> / preauth:<id> / reimbursement:<m> / integration:<key>).
  scopeKey                      String
  channel                       ClaimIntakeChannel
  idempotencyKey                String
  schemaVersion                 String
  // SHA-256 of canonical claim-affecting content (prefixed req:v1:).
  requestHash                   String
  // Authoritative identity hash (strong:v1:) — null when no authoritative id.
  strongEventFingerprint        String?
  // Non-unique content signature (suspect:v1:) — candidate detection only.
  suspectedDuplicateFingerprint String
  // At most one claim per receipt; a claim may have many receipts (cross-rail link).
  claimId                       String?
  claim                         Claim?                  @relation(fields: [claimId], references: [id])
  state                         ClaimIntakeReceiptState @default(PROCESSING)
  outcomeCode                   String? // stable INTAKE_CODES / route code
  safeMessage                   String? // caller-safe message; never raw internals
  httpStatus                    Int?
  correlationId                 String
  processingRuns                ClaimProcessingRun[]
  // Set when this receipt replayed/linked to an earlier receipt (plain ref, no FK
  // self-relation to keep queries simple).
  replayedFromReceiptId         String?
  createdAt                     DateTime                @default(now())
  completedAt                   DateTime?
  updatedAt                     DateTime                @updatedAt

  @@unique([tenantId, scopeKey, channel, idempotencyKey])
  @@index([tenantId, strongEventFingerprint])
  @@index([tenantId, suspectedDuplicateFingerprint])
  @@index([tenantId, state, createdAt])
  @@index([claimId])
}

// ═══════════════════════════════════════════════════════════════════════════
// CLAIMS AUTOPILOT — durable processing run + stage history (F2.3, §9.3–§9.4)
// Database is authoritative (D8): the run/stage rows are the source of truth for
// automated evaluation; BullMQ only accelerates execution.
// ═══════════════════════════════════════════════════════════════════════════

enum ClaimProcessingTrigger {
  INITIAL
  MANUAL_REPROCESS
  DUPLICATE_CLEARED
  DOCUMENTS_UPDATED
  CONFIG_CHANGED
  RECOVERY
}

enum ClaimProcessingState {
  PENDING
  RUNNING
  ROUTED
  SHADOW_COMPLETE
  AUTO_DECIDED
  RETRYABLE
  FAILED
}

enum ClaimProcessingStageName {
  CONTEXT
  ELIGIBILITY
  CODING
  DOCUMENTS
  DUPLICATE
  CONTRACT
  PREAUTH
  BENEFIT
  FRAUD
  COST_SHARE
  POLICY
  DECISION
  NOTIFICATION
  AUDIT
}

enum ClaimProcessingStageState {
  PENDING
  RUNNING
  PASSED
  ROUTED
  SKIPPED
  RETRYABLE
  FAILED
}

model ClaimProcessingRun {
  id              String                 @id @default(cuid())
  tenantId        String
  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  claimId         String
  claim           Claim                  @relation(fields: [claimId], references: [id])
  receiptId       String
  receipt         ClaimIntakeReceipt     @relation(fields: [receiptId], references: [id])
  claimRevision   Int                    @default(1)
  workflowVersion String                 @default("v1")
  sequence        Int                    @default(1) // 1 = initial; authorized reprocess increments
  trigger         ClaimProcessingTrigger @default(INITIAL)
  supersedesRunId String? // terminal run this reprocess supersedes
  modeResolved    String? // resolved OFF/SHADOW/LIVE (text — decoupled from the policy enum)
  policyId        String?
  state           ClaimProcessingState   @default(PENDING)
  currentStage    ClaimProcessingStageName?
  routeCode       String?
  assignedQueue   String?
  safeMessage     String? // no raw stack/payload
  attemptCount    Int                    @default(0)
  nextAttemptAt   DateTime?
  leaseOwner      String?
  leaseExpiresAt  DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  stages ClaimProcessingStage[]

  // At most one run per (claim revision, workflow, sequence).
  @@unique([claimId, claimRevision, workflowVersion, sequence])
  @@index([tenantId, state, nextAttemptAt])
  @@index([tenantId, assignedQueue, state])
  @@index([claimId])
  @@index([receiptId])
}

model ClaimProcessingStage {
  id           String                    @id @default(cuid())
  runId        String
  run          ClaimProcessingRun        @relation(fields: [runId], references: [id])
  stage        ClaimProcessingStageName
  state        ClaimProcessingStageState @default(PENDING)
  attemptCount Int                       @default(0)
  reasonCode   String?
  safeMessage  String?
  result       Json? // safe machine-readable refs/totals only — never raw docs/credentials
  durationMs   Int?
  startedAt    DateTime?
  completedAt  DateTime?
  updatedAt    DateTime                  @updatedAt

  @@unique([runId, stage])
}

// ═══════════════════════════════════════════════════════════════════════════
// CLAIMS AUTOPILOT — governed automation policy mode/status (F2.4, §9.1/§9.6)
// Every scope starts OFF (D1/D2). LIVE requires an APPROVED policy version and a
// finite positive ceiling; activation is maker-checker governed (D15, F2.5).
// ═══════════════════════════════════════════════════════════════════════════

enum AutoAdjudicationMode {
  OFF
  SHADOW
  LIVE
}

enum AutoAdjudicationPolicyStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUPERSEDED
  DEACTIVATED
}

// ═══════════════════════════════════════════════════════════════════════════
// CLAIMS AUTOPILOT — circuit breaker (F4.7, §13.3). Ops can stop LIVE automatic
// decisions per tenant/client immediately without deleting policy history; a
// critical invariant/failure can trip it automatically. History is preserved via
// audit-chain events (AUTO_ADJ:CIRCUIT_BREAKER_OPENED/CLOSED).
// ═══════════════════════════════════════════════════════════════════════════
model ClaimAutopilotBreaker {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  clientId      String? // null = tenant-wide breaker
  isOpen        Boolean   @default(false)
  reason        String?
  autoTriggered Boolean   @default(false)
  openedById    String?
  openedAt      DateTime?
  closedById    String?
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([tenantId, clientId])
  @@index([tenantId, isOpen])
}
