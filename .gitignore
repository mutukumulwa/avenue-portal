# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
artifacts/next-dev-*.log

# env files (can opt-in for committing if needed)
.env*
# ...but the placeholder templates ARE committed as the canonical env convention.
!.env.example
!.env.worker.example

# local DB dumps (contain prod data — never commit)
*-backup*.sql
avenue-prod-backup*.sql

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Binary design-handoff bundle (kept on disk, not in git)
*design-handoff*.zip

# Digital-contract raw source corpus (evidence, not code — do not commit large binaries)
/Contracts/
/contract-mds/
