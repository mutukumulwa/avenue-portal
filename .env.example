# ------------------------------------------------------------------------------
# Medvex portal — environment template.
#
# Copy to `.env` for local dev and fill in real values. In hosted environments
# (Vercel UAT / prod) set these in the platform's env settings, NEVER in git.
# Values here are PLACEHOLDERS — no real secret is ever committed.
#
# Convention: every secret is environment-only. Code must fail closed when a
# secret is missing — it must never fall back to an in-source default (a default
# ships as a live, guessable credential). See docs/API_AUTHENTICATION.md.
# ------------------------------------------------------------------------------

# --- Database (Postgres / Supabase) -------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
# Direct (non-pooled) connection used by Prisma migrations.
DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"

# --- B2B API authentication (/api/v1/*) — SECURITY-CRITICAL (BD-06) -----------
# The operator/global integration key. MUST be a strong random value and MUST be
# set explicitly: there is no in-source default, so an unset/empty API_KEY
# disables the operator channel and every /api/v1 call fails closed (401).
# Generate one with:  node scripts/generate-api-key.mjs
# Rotate by replacing the value and redeploying; the old value dies immediately.
API_KEY=""

# Binds the operator key to a single tenant so it cannot span tenants. Set to the
# operator tenant's id (see the "Tenant" table). Leave blank to keep the legacy
# tenant-wide operator scope (safe only while there is exactly one tenant).
OPERATOR_TENANT_ID=""

# Per-facility HMS keys (prefix "mvxk_") are the PREFERRED integration path and
# are provisioned per-provider in /settings — they are stored hashed in the DB,
# not here. See docs/API_AUTHENTICATION.md.

# --- App / auth ---------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- WebAuthn (branch-approval / step-up) -------------------------------------
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_RP_NAME="Medvex"
WEBAUTHN_ORIGIN="http://localhost:3000"
WEBAUTHN_REGISTRATION_TTL_SECONDS="300"
WEBAUTHN_BRANCH_APPROVAL_TTL_MINUTES="10"
WEBAUTHN_FAILED_LOCKOUT_MINUTES="15"

# --- Provider check-in codes --------------------------------------------------
CHECKIN_CHALLENGE_TTL_SECONDS="120"
CHECKIN_VISIT_CODE_TTL_SECONDS="900"

# --- Object storage (MinIO / S3-compatible) — set real creds in prod ----------
MINIO_ENDPOINT="minio"
MINIO_PORT="9000"
MINIO_ROOT_USER=""
MINIO_ROOT_PASSWORD=""

# --- Email / SMTP -------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="no-reply@medvex.co.ug"

# --- Queue (offline sync / reconcile jobs) ------------------------------------
REDIS_URL="redis://localhost:6379"

# --- Payments -----------------------------------------------------------------
MPESA_CALLBACK_SECRET=""

# --- Adjudication engine feature gates (comma-separated) ----------------------
CONTRACT_ENGINE_GATES=""
