{
  "name": "Medvex Member Portal",
  "short_name": "Medvex",
  "description": "Mobile member access for benefits, dependents, utilization, pre-authorizations, facilities, and support.",
  "start_url": "/member/dashboard",
  "scope": "/",
  "display": "standalone",
  "background_color": "#EEF2F4",
